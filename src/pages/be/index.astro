---
import BeLayout from '@/layouts/BeLayout.astro';
---

<BeLayout
  title="Be — Leigh Bertelsen"
  description="ICF-certified coaching for women in tech who are good at everything except knowing what comes next."
>
  <div class="page">
    <section class="hero" aria-label="Introduction">
      <blockquote class="quote">
        You don't need to burn it all down.
      </blockquote>
      <hr class="rule" />
      <p class="subline">
        ICF-certified coaching for women in tech who are good at everything except
        knowing what comes next.
      </p>
      <a class="cta" href="#offerings">Work with me →</a>
    </section>

    <section class="offerings" id="offerings" aria-label="Ways to work together">
      <h2 class="sr-only">Ways to work together</h2>

      <article class="card">
        <span class="card-label">1:1 coaching</span>
        <h3 class="card-title">Individual sessions</h3>
        <p class="card-body">
          Six or twelve sessions. Space to think, feel, and figure out what you
          actually want.
        </p>
        <a class="card-link" href="/be/about">Learn more →</a>
      </article>

      <article class="card">
        <span class="card-label">deep dive</span>
        <h3 class="card-title">Intensive</h3>
        <p class="card-body">
          A half-day session for when you need clarity fast and you're done waiting
          for it.
        </p>
        <a class="card-link" href="/be/about">Learn more →</a>
      </article>

      <article class="card">
        <span class="card-label">first step</span>
        <h3 class="card-title">Discovery call</h3>
        <p class="card-body">
          A free 30-minute conversation to see if we're a good fit. No pressure,
          no pitch.
        </p>
        <a class="card-link card-link-strong" href="/be/about">Book a call →</a>
      </article>
    </section>
  </div>

  <section class="kind-words" aria-label="Kind words">
    <h2 class="sr-only">Kind words</h2>
    <div class="kind-words-inner">
      <figure class="quote-block">
        <blockquote>
          Working with Leigh changed how I think about my career entirely. I finally
          feel like I'm making decisions for myself.
        </blockquote>
        <figcaption>— Software engineer, Copenhagen</figcaption>
      </figure>

      <figure class="quote-block">
        <blockquote>
          Working with Leigh changed how I think about my career entirely. I finally
          feel like I'm making decisions for myself.
        </blockquote>
        <figcaption>— Software engineer, Copenhagen</figcaption>
      </figure>
    </div>
  </section>
</BeLayout>

<style>
  .page {
    max-width: 720px;
    margin-inline: auto;
    padding: 7rem 2rem 4rem;
  }

  /* ── hero ────────────────────────────────── */
  .hero {
    text-align: center;
  }

  /* NOTE: page-arrival content fade-in will be added in Phase 3b
     (View Transitions pass). No change needed here — reminder only. */
  .quote {
    font-family: var(--font-serif-be);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(32px, 4.5vw, 48px);
    line-height: 1.25;
    color: var(--color-text-primary);
    margin: 0 auto;
    max-width: 16ch;
  }

  .rule {
    border: none;
    border-top: 0.5px solid var(--color-border);
    width: 60px;
    margin: 1.5rem auto;
  }

  .subline {
    font-family: var(--font-serif-be);
    font-weight: 400;
    font-style: normal;
    font-size: 18px;
    line-height: 1.75;
    color: var(--color-text-secondary);
    max-width: 480px;
    margin: 0 auto;
  }

  .cta {
    display: inline-block;
    margin-top: 1.75rem;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 200ms ease;
  }
  .cta:hover { opacity: 0.75; }

  /* ── offerings ───────────────────────────── */
  .offerings {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 4rem;
  }

  .card {
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-label {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .card-title {
    font-family: var(--font-serif-be);
    font-weight: 500;
    font-style: normal;
    font-size: 18px;
    color: var(--color-text-primary);
    margin: 0;
  }

  .card-body {
    font-family: var(--font-serif-be);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .card-link {
    margin-top: auto;
    padding-top: 0.75rem;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 13px;
    color: var(--color-accent);
    text-decoration: none;
    align-self: flex-start;
    transition: opacity 200ms ease;
  }
  .card-link:hover { opacity: 0.75; }
  .card-link-strong { font-weight: 500; }

  /* ── kind words ──────────────────────────── */
  .kind-words {
    margin-top: 4rem;
    background: var(--color-surface);
    border-top: 0.5px solid var(--color-border);
    border-bottom: 0.5px solid var(--color-border);
    padding: 3rem 2rem;
  }

  .kind-words-inner {
    max-width: 860px;
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }

  .quote-block { margin: 0; }
  .quote-block blockquote {
    font-family: var(--font-serif-be);
    font-weight: 400;
    font-style: italic;
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-text-primary);
    margin: 0 0 1rem;
  }
  .quote-block figcaption {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  /* ── mobile ──────────────────────────────── */
  @media (max-width: 767px) {
    .page { padding: 2rem 1.5rem 4rem; }
    .offerings { grid-template-columns: 1fr; }
    .kind-words { padding: 2.5rem 1.5rem; margin-bottom: 4rem; }
    .kind-words-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
