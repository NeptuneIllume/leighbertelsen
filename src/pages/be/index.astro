---
import { Image } from 'astro:assets';
import BeLayout from '@/layouts/BeLayout.astro';
import leighGolden from '@/assets/images/be/leigh-golden-hour.jpg';
import leighCacaoRitual from '@/assets/images/breathe/leigh-cacao-ritual.jpg';
import leighTarotCrystals from '@/assets/images/breathe/leigh-tarot-crystals.jpg';

const quotes = [
  {
    text: "Leigh helped me find the focal point and made me feel comfortable during the process.",
    attr: 'Cat, after a Clarity Coaching session',
  },
  {
    text: "Her coaching is helpful for anyone needing clarity and direction. Leigh held space for me to find my truth and my soul's voice.",
    attr: 'Kristina, after a Clarity Coaching session',
  },
  {
    text: "It was incredibly fulfilling working with Leigh. Her questions and our conversations helped reveal the areas in my life which needed attention — she helped create an accountable action plan, though quite gentle, to bring energy to those areas and inspire growth.",
    attr: 'Sara, after an ICF coaching session',
  },
  {
    text: "She taught me how to accomplish my professional goals but also take time for spiritual and fun activities that I tend to pay less attention to but need more of in my life.",
    attr: 'Nadine, coaching client',
  },
];
---

<BeLayout
  title="Life Coach for Women in Tech Copenhagen | Leigh Bertelsen"
  description="ICF-accredited coaching for women in tech who are good at everything except knowing what comes next. Based outside Copenhagen, working online worldwide."
>
  <div class="page">

    {/* ── Hero — kept exactly as-is ─────────────────────── */}
    <section class="hero" aria-label="Introduction">
      <blockquote class="quote">
        You don't need to burn it all down.
      </blockquote>
      <hr class="rule" />
      <p class="subline">
        ICF-accredited coaching for women in tech who know
        something needs to change, even if they don’t yet know what.
      </p>
      <a class="cta" href="#offerings">work with me</a>
    </section>

    <Image
      src={leighGolden}
      alt="Leigh Bertelsen in a sunlit field outside Copenhagen"
      widths={[400, 800]}
      sizes="(max-width: 768px) 100vw, 480px"
      class="be-portrait"
    />

    {/* ── Offerings ────────────────────────────────────── */}
    <section class="offerings" id="offerings" aria-label="Ways to work together">
      <h2 class="sr-only">Ways to work together</h2>

      <article class="card">
        <span class="card-label">1:1 coaching</span>
        <h3 class="card-title">A series of sessions</h3>
        <p class="card-body">
          Five or ten sessions, held online. We use self-inquiry, mindfulness, and practices
          drawn from yoga and somatic work to help you get clear on what you actually want
          and move toward it. Sessions can be mixed: coaching, yoga, or tarot, depending on
          where you are and what you need.
        </p>
        <a class="card-link" href="/be/method">how sessions work</a>
      </article>

      <article class="card">
        <span class="card-label">deep dive</span>
        <h3 class="card-title">Half-day intensive</h3>
        <p class="card-body">
          For when you need clarity and you're done waiting for it. We go deep in one
          focused session, useful when you're at a crossroads and slow isn't an option.
        </p>
        <a class="card-link" href="/be/method">about the intensive</a>
      </article>

      <article class="card">
        <span class="card-label">first step</span>
        <h3 class="card-title">A free conversation</h3>
        <p class="card-body">
          Before anything else, we talk. Thirty minutes to see if this feels right for both
          of us. No pitch, no pressure, just an honest conversation about where you are and
          whether I can actually help.
        </p>
        <a class="card-link" href="https://calendly.com/leigh-olesen/coaching-discovery-session" target="_blank" rel="noopener">book a call</a>
      </article>
    </section>

    {/* ── Pricing ──────────────────────────────────────── */}
    <section class="pricing" aria-label="Investment">
      <p class="section-label">investment</p>
      <h2 class="pricing-title">Pricing</h2>
      <p class="pricing-body">
        Sessions are available in packs of five or ten. A pack of five sessions and the
        half-day intensive are each 7,750 kr or $1,100. A pack of ten sessions is 14,100 kr
        or $2,000. Sessions are not sold individually. In my experience, the deepest
        discoveries need time to grow.
      </p>
      <p class="pricing-body">
        It is possible to combine session types across a pack, for example five coaching
        sessions, four yoga sessions, and one tarot reading. Sessions are held online and
        in English. A free discovery call is required before purchase, so we can make sure
        this is the right fit.
      </p>
      <a class="pricing-cta" href="https://calendly.com/leigh-olesen/coaching-discovery-session" target="_blank" rel="noopener">
        book your free call
      </a>
    </section>

    {/* ── Kind words ───────────────────────────────────── */}
    <section class="kind-words" aria-label="Kind words">
      <h2 class="sr-only">Kind words</h2>
      <ul class="quotes-grid" role="list">
        {quotes.map((q) => (
          <li class="quote-card">
            <blockquote class="quote-text">"{q.text}"</blockquote>
            <footer class="quote-attr">— {q.attr}</footer>
          </li>
        ))}
      </ul>
    </section>

    {/* ── Ritual pair ──────────────────────────────────── */}
    <div class="photo-pair">
      <Image
        src={leighCacaoRitual}
        alt="Cacao ceremony setup with candle and palo santo on a turquoise table"
        widths={[400, 700]}
        sizes="(max-width: 640px) 100vw, 45vw"
        class="pair-photo"
      />
      <Image
        src={leighTarotCrystals}
        alt="Tarot cards and crystals including the Three of Cups"
        widths={[400, 700]}
        sizes="(max-width: 640px) 100vw, 45vw"
        class="pair-photo"
      />
    </div>

  </div>
</BeLayout>

<style>
  .page {
    max-width: 720px;
    margin-inline: auto;
    padding: 7rem 2rem 5rem;
  }

  /* ── hero ────────────────────────────────── */
  .hero { text-align: center; }

  /* NOTE: page-arrival content fade-in will be added in Phase 3b
     (View Transitions pass). No change needed here — reminder only. */
  .quote {
    font-family: var(--font-serif-be);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(32px, 4.5vw, 48px);
    line-height: 1.25;
    color: var(--color-text-primary);
    margin: 0 auto;
    max-width: 16ch;
  }

  .rule {
    border: none;
    border-top: 0.5px solid var(--color-border);
    width: 60px;
    margin: 1.5rem auto;
  }

  .subline {
    font-family: var(--font-serif-be);
    font-weight: 400;
    font-style: normal;
    font-size: clamp(15px, 2vw, 18px);
    line-height: 1.75;
    color: var(--color-text-secondary);
    max-width: 480px;
    margin: 0 auto;
  }

  .cta {
    display: inline-block;
    margin-top: 1.75rem;
    font-family: var(--font-serif-be);
    font-weight: 400;
    font-size: 14px;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 200ms ease;
  }
  .cta:hover { opacity: 0.75; }

  /* ── portrait ───────────────────────────── */
  .be-portrait {
    width: 100%;
    max-width: 480px;
    height: auto;
    max-height: 70vh;
    border-radius: 8px;
    display: block;
    margin: 2.5rem auto;
    aspect-ratio: auto;
    object-fit: contain;
  }

  /* ── offerings ───────────────────────────── */
  .offerings {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 4rem;
  }

  .card {
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-label {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .card-title {
    font-family: var(--font-serif-be);
    font-weight: 500;
    font-style: normal;
    font-size: 18px;
    color: var(--color-text-primary);
    margin: 0;
  }

  .card-body {
    font-family: var(--font-serif-be);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .card-link {
    margin-top: auto;
    padding-top: 0.75rem;
    font-family: var(--font-serif-be);
    font-weight: 400;
    font-size: 14px;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    text-decoration: none;
    align-self: flex-start;
    transition: opacity 200ms ease;
  }
  .card-link:hover { opacity: 0.75; }

  /* ── pricing ─────────────────────────────── */
  .pricing {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 0.5px solid var(--color-border);
  }

  .section-label {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.75rem;
  }

  .pricing-title {
    font-family: var(--font-serif-be);
    font-weight: 500;
    font-style: normal;
    font-size: 22px;
    color: var(--color-text-primary);
    margin: 0 0 1.25rem;
  }

  .pricing-body {
    font-family: var(--font-serif-be);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin: 0 0 1em;
    max-width: 65ch;
  }
  .pricing-body:last-of-type { margin-bottom: 0; }

  .pricing-cta {
    display: inline-block;
    margin-top: 1.25rem;
    font-family: var(--font-serif-be);
    font-weight: 400;
    font-size: 14px;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 200ms ease;
  }
  .pricing-cta:hover { opacity: 0.75; }

  /* ── ritual pair ─────────────────────────── */
  .photo-pair {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin: 3rem auto;
    max-width: 720px;
  }
  @media (max-width: 640px) {
    .photo-pair { grid-template-columns: 1fr; }
  }
  .pair-photo {
    width: 100%;
    height: auto;
    border-radius: 8px;
    aspect-ratio: 1/1;
    object-fit: cover;
  }

  /* ── kind words ──────────────────────────── */
  .kind-words {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 0.5px solid var(--color-border);
  }

  .quotes-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .quote-card {
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .quote-text {
    font-family: var(--font-serif-be);
    font-weight: 400;
    font-style: italic;
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-text-primary);
    margin: 0;
  }

  .quote-attr {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  /* ── utilities ───────────────────────────── */
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  /* ── mobile ──────────────────────────────── */
  @media (max-width: 767px) {
    .page { padding: 5rem 1.5rem 5rem; }
    .rule { width: 40px; }
    .offerings { grid-template-columns: 1fr; }
    .quotes-grid { grid-template-columns: 1fr; }
  }
</style>
