---
import { getCollection, type CollectionEntry } from 'astro:content';
import BuildLayout from '@/layouts/BuildLayout.astro';
import BreatheLayout from '@/layouts/BreatheLayout.astro';
import BeLayout from '@/layouts/BeLayout.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'posts'> };
const { post } = Astro.props;
const { Content } = await post.render();

const world = post.data.world;

const backLinks: Record<string, string> = {
  build:    '/build/writing',
  breathe:  '/breathe/writing',
  be:       '/be/writing',
  personal: '/personal',
};
const backLink = backLinks[world] ?? '/';

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---

{world === 'build' && (
  <BuildLayout title={`${post.data.title} — Build`} description={post.data.excerpt}>
    <article class="post build">
      <a class="back" href={backLink}>← Writing</a>
      <time class="date" datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
      <h1 class="title">{post.data.title}</h1>
      <div class="body build-post">
        <Content />
      </div>
    </article>
  </BuildLayout>
)}

{world === 'breathe' && (
  <BreatheLayout title={`${post.data.title} — Breathe`} description={post.data.excerpt}>
    <article class="post breathe">
      <a class="back" href={backLink}>← Writing</a>
      <time class="date" datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
      <h1 class="title">{post.data.title}</h1>
      <div class="body">
        <Content />
      </div>
    </article>
  </BreatheLayout>
)}

{world === 'be' && (
  <BeLayout title={`${post.data.title} — Be`} description={post.data.excerpt}>
    <article class="post be">
      <a class="back" href={backLink}>← Writing</a>
      <time class="date" datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
      <h1 class="title">{post.data.title}</h1>
      <div class="body">
        <Content />
      </div>
    </article>
  </BeLayout>
)}

{world === 'personal' && (
  <BaseLayout title={post.data.title} description={post.data.excerpt} theme="membrane">
    <article class="post personal">
      <a class="back" href={backLink}>← back</a>
      <time class="date" datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
      <h1 class="title">{post.data.title}</h1>
      <div class="body">
        <Content />
      </div>
    </article>
  </BaseLayout>
)}

<style>
  /* ── shared post shell ──────────────────────── */
  .post {
    max-width: 65ch;
    margin-inline: auto;
    padding: 6rem 2rem 5rem;
  }
  @media (max-width: 767px) {
    .post { padding: 5rem 1.25rem 6rem; }
  }

  .back {
    display: inline-block;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 12px;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 200ms ease;
  }
  .back:hover { color: var(--color-accent); }

  .date {
    display: block;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
  }

  /* Build date: Fragment Mono */
  .build .date {
    font-family: var(--font-mono);
  }

  /* ── title: world-specific fonts ───────────── */
  .build .title {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(28px, 4vw, 42px);
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--color-text-primary);
    margin: 0 0 2.5rem;
  }

  .breathe .title {
    font-family: var(--font-serif-breathe);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(32px, 5vw, 52px);
    line-height: 1.15;
    color: var(--color-text-primary);
    margin: 0 0 2.5rem;
  }

  .be .title {
    font-family: var(--font-serif-be);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.2;
    color: var(--color-text-primary);
    margin: 0 0 2.5rem;
  }

  .personal .title {
    font-family: var(--font-serif-breathe);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.2;
    color: #2C2416;
    margin: 0 0 2.5rem;
  }

  /* ── body prose ─────────────────────────────── */
  .build .body {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 17px;
    line-height: 1.75;
    color: var(--color-text-secondary);
  }

  .breathe .body {
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.75;
    color: var(--color-text-secondary);
  }

  .be .body {
    font-family: var(--font-serif-be);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.75;
    color: var(--color-text-secondary);
  }

  .personal .body {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 17px;
    line-height: 1.75;
    color: #5C4A2A;
  }

  /* Shared prose elements */
  .body :global(p)      { margin: 0 0 1.25em; }
  .body :global(h2)     { margin: 2em 0 0.5em; }
  .body :global(h3)     { margin: 1.75em 0 0.4em; }
  .body :global(ul),
  .body :global(ol)     { padding-left: 1.5rem; margin: 0 0 1.25em; }
  .body :global(li)     { margin-bottom: 0.4em; }
  .body :global(strong) { font-weight: 500; color: var(--color-text-primary); }
  .body :global(em)     { font-style: italic; }
  .body :global(a)      { color: var(--color-accent); }
  .body :global(code)   {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: 3px;
    padding: 0.1em 0.35em;
  }

  /* ── build post gutter counter ─────────────────── */
  .build-post {
    counter-reset: gutter;
    padding-left: 3.5rem;
  }

  .build-post :global(> p),
  .build-post :global(> h2),
  .build-post :global(> h3),
  .build-post :global(> ul),
  .build-post :global(> ol),
  .build-post :global(> blockquote),
  .build-post :global(> pre) {
    counter-increment: gutter;
    position: relative;
  }

  .build-post :global(> p)::before,
  .build-post :global(> h2)::before,
  .build-post :global(> h3)::before,
  .build-post :global(> ul)::before,
  .build-post :global(> ol)::before,
  .build-post :global(> blockquote)::before,
  .build-post :global(> pre)::before {
    content: counter(gutter, decimal-leading-zero);
    position: absolute;
    left: -3rem;
    top: 0.4em;
    font-family: var(--font-mono);
    font-size: 12px;
    color: color-mix(in srgb, var(--color-accent) 50%, transparent);
    user-select: none;
    pointer-events: none;
  }

  @media (max-width: 640px) {
    .build-post {
      padding-left: 0;
    }
    .build-post :global(> *)::before {
      display: none;
    }
  }
</style>
