---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Sigil from '@/components/ui/Sigil.astro';

const choices = [
  {
    num: '01',
    name: 'Build',
    href: '/build',
    subtitle: 'You\'re looking for a developer, or you are one.',
    hover: '#1A6FBF',
  },
  {
    num: '02',
    name: 'Breathe',
    href: '/breathe',
    subtitle: 'You\'re here for the mat, the circle, the turning of the year.',
    hover: '#C45A2A',
  },
  {
    num: '03',
    name: 'Be',
    href: '/be',
    subtitle: 'You\'re exhausted by what you\'ve become good at.',
    hover: '#3A6050',
  },
];
---

<BaseLayout title="Leigh Bertelsen" description="One person, three worlds. Choose where to begin.">
  {/* Suppress BaseLayout's default header — membrane positions its own sigil. */}
  <Fragment slot="header" />

  <div class="page">
    <span class="sigil-pill" aria-label="Leigh Bertelsen">
      <Sigil size={22} />
    </span>

    <section class="membrane" transition:name="membrane-content">
      <p class="prompt">— where would you like to go? —</p>

      <nav class="choices" aria-label="Choose a world">
        {choices.map((c, i) => (
          <>
            <a href={c.href} class="choice" style={`--hover: ${c.hover};`}>
              <span class="num">{c.num}</span>
              <span class="name">{c.name}</span>
              <span class="sub">{c.subtitle}</span>
            </a>
            {i < choices.length - 1 && <span class="sep" aria-hidden="true">·</span>}
          </>
        ))}
      </nav>
    </section>
  </div>
</BaseLayout>

<script>
  import gsap from 'gsap';

  // Expose for devtools inspection.
  (window as any).gsap = gsap;

  let ctx: any = null;

  function init() {
    ctx?.revert();

    const root = document.querySelector('.page');
    if (!root) {
      console.warn('[membrane] .page not found — script running before DOM?');
      return;
    }

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    console.log('[membrane] init — gsap', gsap.version, 'reduced:', prefersReduced);

    ctx = gsap.context(() => {
      const choices = gsap.utils.toArray<HTMLAnchorElement>('.choice');
      const seps    = gsap.utils.toArray<HTMLSpanElement>('.sep');
      console.log('[membrane] choices:', choices.length, 'seps:', seps.length);

      if (prefersReduced) {
        gsap.set(['.sigil-pill', '.prompt', '.choice', '.sep'], { opacity: 1, y: 0, scale: 1 });
      } else {
        gsap.set('.sigil-pill', { opacity: 0, scale: 0.9, transformOrigin: '50% 50%' });
        gsap.set('.prompt',     { opacity: 0, y: 8 });
        gsap.set('.choice',     { opacity: 0, y: 16 });
        gsap.set('.sep',        { opacity: 0 });

        gsap.timeline()
          .to('.sigil-pill', { opacity: 1, scale: 1, duration: 0.6, ease: 'power2.out' }, 0)
          .to('.prompt',     { opacity: 1, y: 0,     duration: 0.5 },                    0.2)
          .to('.choice',     { opacity: 1, y: 0,     duration: 0.6,
                               stagger: 0.12, ease: 'power2.out' },                      0.4)
          .to('.sep',        { opacity: 1, duration: 0.4 },                              0.52);
      }

      choices.forEach((clicked) => {
        clicked.addEventListener('click', (ev) => {
          if (ev.metaKey || ev.ctrlKey || ev.shiftKey || ev.altKey || ev.button !== 0) return;
          if (prefersReduced) return;

          ev.preventDefault();
          const href = clicked.getAttribute('href') ?? '/';
          const others = choices.filter((c) => c !== clicked);

          gsap.timeline({ onComplete: () => window.location.assign(href) })
            .to(clicked, { scale: 1.04, opacity: 0, y: -20, duration: 0.4, ease: 'power2.out' }, 0)
            .to([...others, ...seps],
                { opacity: 0, y: 20, scale: 0.96, duration: 0.3, stagger: 0.06 },                0)
            .to('.prompt', { opacity: 0, duration: 0.2 },                                        0);
        });
      });
    }, root);
  }

  // Run on initial hard load (DOM is ready — Astro <script> is deferred/bundled)
  // and on every soft navigation back to this page.
  init();
  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', () => { ctx?.revert(); ctx = null; });
</script>

<style>
  .page {
    position: relative;
    min-height: 100dvh;
  }

  /* Hide animated elements by default so there's no flash before GSAP's
     .set() runs on slow connections. GSAP clears these immediately, or
     the prefers-reduced-motion branch restores them via clearProps. */
  .sigil-pill,
  .prompt,
  .choice,
  .sep {
    opacity: 0;
  }

  .sigil-pill {
    position: absolute;
    top: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    border: 0.5px solid var(--color-border);
    border-radius: 99px;
    padding: 6px 20px;
    color: var(--color-text);
  }

  .membrane {
    height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    text-align: center;
    gap: 2rem;
  }

  .prompt {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 13px;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin: 0;
  }

  .choices {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: nowrap;
    width: 100%;
    max-width: 1200px;
  }

  .sep {
    font-family: var(--font-serif-breathe);
    font-weight: 300;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    color: var(--color-text-muted);
    align-self: center;
    user-select: none;
    transform: translateY(-0.1em);
  }

  .choice {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: inherit;
    flex: 0 1 auto;
    min-width: 0;
    padding: 0.25rem 0.5rem;
  }

  .num {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .name {
    font-family: var(--font-serif-breathe);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(40px, 8vw, 72px);
    line-height: 1;
    color: var(--color-text);
    transition: color 280ms ease;
  }

  .choice:hover .name,
  .choice:focus-visible .name {
    color: var(--hover);
  }

  .sub {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    max-width: 22ch;
    line-height: 1.45;
  }

  /* Stack vertically on narrow viewports — three 40px italic words plus
     separators won't fit horizontally below ~640px without crowding. */
  @media (max-width: 640px) {
    .membrane {
      /* Reserve room at the top for the absolute sigil pill (sits at
         top: 2rem and is ~44px tall) so vertically centered content
         doesn't ride up underneath it on short viewports. */
      padding: 6rem 1.5rem 4rem;
      justify-content: flex-start;
      gap: 3rem;
    }
    .choices {
      flex-direction: column;
      align-items: center;
      gap: 2.5rem;
    }
    .sep { display: none; }
    .sub {
      /* Slightly larger for readability on mobile (was 11px). */
      font-size: 13px;
      max-width: 28ch;
    }
  }
</style>
