---
import { Image, getImage } from 'astro:assets';
import BreatheLayout from '@/layouts/BreatheLayout.astro';
import Sigil from '@/components/ui/Sigil.astro';
import leighBali from '@/assets/images/breathe/leigh-bali-temple.jpg';
import leighWarrior from '@/assets/images/breathe/leigh-hi-warrior.jpg';
import leighHiKarma from '@/assets/images/breathe/leigh-hi-karma.png';
import leighSunriseHimalayas from '@/assets/images/breathe/leigh-sunrise-himalayas.png';
import gomde from '@/assets/images/breathe/gomde-prayer-flags.png';
import altarGoddessAvalon from '@/assets/images/breathe/altar-goddess-avalon.png';
import leighMekong from '@/assets/images/breathe/leigh-mekong-boat.jpg';
import { getLastModified } from '@/utils/lastModified';

const preloadBali = await getImage({ src: leighBali, width: 1200, format: 'webp' });

const lastEdited = getLastModified('src/pages/breathe/about/index.astro');

const quotes = [
  {
    text: "I took your Sunday classes at NOR: a while ago and I loved your style of teaching Yin. It felt relaxing, meditative and flowy.",
    attr: 'Katrine, student',
  },
  {
    text: "You are incredibly language-oriented, from computers, to the body, to the soul, and to the soil.",
    attr: 'Siobhan, peer',
  },
];
---

<link rel="preload" as="image" href={preloadBali.src} slot="head" />

<BreatheLayout
  title="About | Breathe | Leigh Bertelsen"
  description="500-hour yoga teacher (Himalayan Institute), Priestess facilitator, and contemplative practitioner. Teaching online and seasonal circles."
>
  <div class="page">

    {/* 1. Hero — Bali temple ─────────────────────────────── */}
    <figure class="hero-figure">
      <Image
        src={leighBali}
        alt="Leigh Bertelsen sitting at a temple doorway in Bali with a koi pond in the foreground"
        widths={[800, 1200, 1600]}
        sizes="100vw"
        class="hero-photo"
      />
      <figcaption class="hero-caption"><em>Pura Tirta Empul, Bali.</em></figcaption>
    </figure>

    {/* ── Opening ────────────────────────────────────────── */}
    <section class="intro" aria-label="Introduction">
      <p class="body drop-cap">
        I've been practicing yoga for most of my adult life and teaching for over a decade.
        My path into it was never straight, which is probably why I teach the way I do.
      </p>
      <div class="pull-anchor">
        <p class="body">
          I've taught in Denmark, Laos, Thailand, Nepal, Austria, India, and the US. In
          studios, at universities, in corporate settings, and online. The common thread has
          always been the same: meeting people where they are, and offering something that's
          actually useful.
        </p>
        <aside class="pull-quote" aria-hidden="true">
          "The common thread has always been the same: meeting people where they are, and offering something that's actually useful."
        </aside>
      </div>
    </section>

    {/* ── The foundation ─────────────────────────────────── */}
    <section class="section" aria-label="Training">
      <p class="section-label">training</p>
      <h2 class="section-title">The foundation</h2>

      {/* PAIRING 1 — paired thumbs beside training paragraphs */}
      <div class="photo-row photo-row--right">
        <div class="text-col">
          <p class="body drop-cap">
            My formal training began with a 250-hour Vinyasa certification and a 40-hour Yin
            training with Corina Benner at Wake Up Yoga in Philadelphia. I added an Ayurveda
            Yoga Specialist certification with Kathryn Templeton, a Restorative Yoga Teacher
            Training with Cyndi Lee, a Yoga Nidra Teacher Training with Hilary Jackendoff, and
            a Reiki Level 1 attunement. In 2016 I completed the 500-hour Hatha yoga teacher
            training with the Himalayan Institute faculty: Pandit Rajmani Tigunait, Rolf Sovik,
            Sandra Anderson, Shari Friedrichsen, and Judy Moulton, along with separate
            programmes in Yoga Nidra, Samkhya philosophy, and Ashtanga fundamentals with David
            Swenson. I hold the Yoga Alliance RYT-500 certification.
          </p>
          <p class="body">
            From 2025 to 2026 I completed the Priestess Facilitation Training with Sianna
            Sherman, a nine-month container exploring the Wheel of the Year, dream temples,
            sacred circles, ritual facilitation, moon and zodiac magic, and more. This training
            is the direct source of the seasonal gatherings I offer.
          </p>
        </div>
        <div class="photo-thumbs">
          <figure class="thumb-figure">
            <Image
              src={leighWarrior}
              alt="Leigh Bertelsen and another teacher in warrior pose at the Himalayan Institute in autumn"
              widths={[300, 600]}
              sizes="(max-width: 640px) 45vw, 22vw"
              class="thumb-photo"
            />
            <figcaption class="thumb-caption"><em>Warrior pose, Himalayan Institute.</em></figcaption>
          </figure>
          <figure class="thumb-figure">
            <Image
              src={leighHiKarma}
              alt="Karma yoga at the Himalayan Institute"
              widths={[300, 600]}
              sizes="(max-width: 640px) 45vw, 22vw"
              class="thumb-photo"
            />
            <figcaption class="thumb-caption"><em>Karma yoga at Himalayan Institute.</em></figcaption>
          </figure>
        </div>
      </div>
    </section>

    {/* ── Going further ──────────────────────────────────── */}
    <section class="section" aria-label="The study">
      <p class="section-label">the study</p>
      <h2 class="section-title">Going further</h2>

      {/* PAIRING 2 — paired thumbs beside Gomde/Kopan paragraph */}
      <div class="photo-row photo-row--right">
        <div class="text-col">
          <p class="body drop-cap">
            The formal training was only the beginning. I've spent years in serious study of
            contemplative practice across traditions: a three-month accredited summer course at
            Gomde Germany-Austria through the Rangjung Yeshe Institute, where I studied with
            Chökyi Nyima Rinpoche and faculty from Harvard, Oxford, and beyond; a 30-day course
            at Kopan Monastery in Kathmandu taught by Venerable Robina Courtin; and courses at
            Tushita Meditation Centre in Dharamshala with Venerable Drolma. I've also studied
            Yoga and Shamanism with Ray Crist at Kripalu, and the Psychology of the Chakras
            with Anodea Judith.
          </p>
        </div>
        <div class="photo-thumbs">
          <figure class="thumb-figure">
            <Image
              src={leighSunriseHimalayas}
              alt="New Year's Day sunrise over the Himalayas, Nepal"
              widths={[300, 600]}
              sizes="(max-width: 640px) 45vw, 22vw"
              class="thumb-photo"
            />
            <figcaption class="thumb-caption"><em>New Year's Day sunrise over the Himalayas, Nepal.</em></figcaption>
          </figure>
          <figure class="thumb-figure">
            <Image
              src={gomde}
              alt="Prayer flags at Gomde, Germany-Austria"
              widths={[300, 600]}
              sizes="(max-width: 640px) 45vw, 22vw"
              class="thumb-photo"
            />
            <figcaption class="thumb-caption"><em>Prayer flags at Gomde, Germany-Austria.</em></figcaption>
          </figure>
        </div>
      </div>

      {/* PAIRING 3 — single photo left, tarot paragraph right (alternates side) */}
      <div class="photo-row photo-row--left">
        <figure class="thumb-figure">
          <Image
            src={altarGoddessAvalon}
            alt="Altar to Brighid at the Goddess Temple, Avalon"
            widths={[400, 800]}
            sizes="(max-width: 640px) 100vw, 38vw"
            class="thumb-photo thumb-photo--tall"
          />
          <figcaption class="thumb-caption"><em>Altar to Brighid at the Goddess Temple, Avalon.</em></figcaption>
        </figure>
        <div class="text-col">
          <div class="pull-anchor">
            <p class="body">
              I've been reading tarot for 25 years, and have studied witchcraft, paganism,
              Gnosticism, Mahayana Buddhism, and Hindu Tantra in the Sri Vidya lineage. After
              years of looking for the definitive teacher or the definitive practice, I eventually
              stopped looking and started weaving. What I teach comes from everything I've
              absorbed, filtered through what I've actually found to be true.
            </p>
            <aside class="pull-quote" aria-hidden="true">
              "After years of looking for the definitive teacher or the definitive practice, I eventually stopped looking and started weaving."
            </aside>
          </div>
        </div>
      </div>
    </section>

    {/* ── What to expect ─────────────────────────────────── */}
    <section class="section" aria-label="How I work">
      <p class="section-label">how I work</p>
      <h2 class="section-title">What to expect</h2>
      <p class="body drop-cap">
        I work one-to-one, online, with people looking for something more personalised than
        a class setting offers. Some come for the physical practice. Some come for Yoga
        Nidra or meditation. Some want Ayurvedic guidance or tarot woven in. Some are at a
        crossroads and yoga is part of how they think. We figure it out together.
      </p>
      <p class="body">
        I'm also an ICF-accredited coach, trained through She Leads (formerly The Clique
        Method), and that informs how I hold sessions. I listen carefully,
        and I follow what's actually needed rather than a fixed curriculum. The Wheel of the
        Year gatherings are a different kind of offering: communal, ritual, open, and rooted
        in the Priestess training. They're for people who want to mark the turning of the
        seasons with others who take that seriously.
      </p>
    </section>

    {/* ── Atmospheric divider — Mekong ──────────────────────── */}
    <figure class="photo-divider">
      <Image
        src={leighMekong}
        alt="View from the bow of a slow boat on the Mekong river in Laos, looking toward green mountains"
        widths={[600, 1000]}
        sizes="(max-width: 640px) 90vw, 60vw"
        class="divider-photo"
      />
      <figcaption class="thumb-caption"><em>On the slow boat, Mekong River.</em></figcaption>
    </figure>

    {/* ── Kind words ─────────────────────────────────────── */}
    <section class="section" aria-label="Kind words">
      <p class="section-label">kind words</p>
      <ul class="quotes-grid" role="list">
        {quotes.map((q) => (
          <li class="quote-card">
            <blockquote class="quote-text">"{q.text}"</blockquote>
            <footer class="quote-attr">— {q.attr}</footer>
          </li>
        ))}
      </ul>
    </section>

    {/* ── Contact ────────────────────────────────────────── */}
    <section class="section" aria-label="Get in touch">
      <p class="section-label">get in touch</p>
      <p class="body">If any of this resonates, I'd love to hear from you.</p>
      {/* Entity-encoded mailto: leigh.bertelsen@gmail.com */}
      <a class="contact-link" href="&#109;&#97;&#105;&#108;&#116;&#111;&#58;&#108;&#101;&#105;&#103;&#104;&#46;&#98;&#101;&#114;&#116;&#101;&#108;&#115;&#101;&#110;&#64;&#103;&#109;&#97;&#105;&#108;&#46;&#99;&#111;&#109;">
        get in touch
      </a>
    </section>

  </div>

  <footer class="site-footer" slot="footer">
    {lastEdited && (
      <p class="last-updated">last edited {lastEdited}</p>
    )}
    <button class="footer-signature" aria-label="Sigil" data-egg-sigil data-egg-target="/personal">
      <Sigil size={20} />
      <span class="footer-text">linger here a moment</span>
    </button>
  </footer>
</BreatheLayout>

<style>
  .page {
    max-width: 760px;
    margin-inline: auto;
    padding: 6rem 2rem 5rem;
  }
  @media (max-width: 767px) {
    .page { padding: 5rem 1.5rem 6rem; }
  }

  /* ── hero ─────────────────────────────── */
  .hero-figure {
    margin: 0 0 3rem;
  }

  .hero-photo {
    width: 100%;
    max-width: 760px;
    height: auto;
    border-radius: 8px;
    display: block;
    margin: 0 auto;
    aspect-ratio: 4/3;
    object-fit: cover;
    object-position: center;
  }

  .hero-caption {
    font-family: var(--font-serif-breathe);
    font-style: italic;
    font-size: 13px;
    line-height: 1.4;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 0.6rem;
  }

  /* ── magazine-spread photo rows ────────── */
  .photo-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: start;
    margin-top: 1.5rem;
  }

  @media (min-width: 641px) {
    .photo-row--right {
      /* text left (50fr), photos right (45fr) */
      grid-template-columns: 50fr 45fr;
    }
    .photo-row--left {
      /* photo left (45fr), text right (50fr) */
      grid-template-columns: 45fr 50fr;
    }
  }

  .text-col {
    /* passthrough — content constrained by column width */
  }

  /* ── paired thumbnails ──────────────────── */
  .photo-thumbs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.625rem;
    align-items: start;
  }

  /* ── individual thumb ───────────────────── */
  .thumb-figure {
    margin: 0;
  }

  .thumb-photo {
    width: 100%;
    height: auto;
    border-radius: 6px;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .thumb-photo--tall {
    aspect-ratio: 3/4;
  }

  .thumb-caption {
    font-family: var(--font-serif-breathe);
    font-style: italic;
    font-size: 12px;
    line-height: 1.4;
    color: var(--color-text-muted);
    margin-top: 0.4rem;
    display: block;
  }

  /* ── atmospheric divider ────────────────── */
  .photo-divider {
    margin: 3.5rem auto;
    max-width: 60%;
    text-align: center;
  }
  @media (max-width: 640px) {
    .photo-divider { max-width: 90%; }
  }

  .divider-photo {
    width: 100%;
    height: auto;
    border-radius: 8px;
    aspect-ratio: 16/9;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }

  /* ── mobile: collapse photo-row--left single photo ── */
  @media (max-width: 640px) {
    .photo-row--left .thumb-photo--tall {
      aspect-ratio: 4/3;
    }
  }

  /* ── body prose ───────────────────────── */
  .body {
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-size: 18px;
    line-height: 1.7;
    color: var(--color-text-primary);
    margin: 0 0 1.25em;
    max-width: 65ch;
  }
  .body:last-of-type { margin-bottom: 0; }

  /* ── section chrome ───────────────────── */
  .section {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 0.5px solid var(--color-border);
  }

  .section-label {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.75rem;
  }

  .section-title {
    font-family: var(--font-serif-breathe);
    font-weight: 300;
    font-style: italic;
    font-size: 28px;
    line-height: 1.2;
    color: var(--color-text-primary);
    margin: 0 0 1.5rem;
  }

  /* ── kind words ───────────────────────── */
  .quotes-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 640px) {
    .quotes-grid { grid-template-columns: 1fr; }
  }

  .quote-card {
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .quote-text {
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-style: italic;
    font-size: 18px;
    line-height: 1.7;
    color: var(--color-text-primary);
    margin: 0;
  }

  .quote-attr {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  /* ── contact ──────────────────────────── */
  .contact-link {
    display: inline-block;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 15px;
    font-style: italic;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: 1rem;
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0% 100%;
    background-repeat: no-repeat;
    background-size: 0% 1px;
    transition: background-size 350ms ease;
  }
  .contact-link:hover { background-size: 100% 1px; }

  /* ── footer ───────────────────────────── */
  .site-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 3rem 1.5rem 2rem;
  }  .footer-signature {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0.6;
    background: none;
    border: none;
    padding: 0.5rem;
    margin: -0.5rem;
    cursor: pointer;
    transition: opacity 200ms ease;
    transform-origin: center;
  }
  .footer-signature:hover {
    opacity: 0.85;
  }
  .footer-text {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 300;
    font-style: italic;
    letter-spacing: 0.02em;
    color: var(--color-text-secondary);
    user-select: none;
  }  .last-updated {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 14px;
    font-style: italic;
    color: var(--color-tab-dim);
    margin: 0;
  }

  /* ── drop caps ────────────────────────── */
  .body.drop-cap::first-letter {
    font-family: var(--font-serif-breathe);
    font-style: italic;
    font-weight: 400;
    font-size: 4em;
    line-height: 1;
    float: left;
    padding-right: 0.08em;
    padding-top: 0.05em;
    color: color-mix(in srgb, var(--color-accent) 80%, var(--color-text-primary));
  }

  /* ── pull quotes ──────────────────────── */
  .pull-anchor {
    position: relative;
  }

  .pull-quote {
    font-family: var(--font-serif-breathe);
    font-style: italic;
    font-size: 1.4em;
    line-height: 1.3;
    color: color-mix(in srgb, var(--color-text-primary) 80%, transparent);
    width: 14rem;
    position: absolute;
    right: -16rem;
    top: 0;
    margin: 0;
  }

  @media (max-width: 1440px) {
    .pull-quote {
      position: static;
      width: 100%;
      margin: 1.5rem 0;
      text-align: center;
    }
  }
</style>
