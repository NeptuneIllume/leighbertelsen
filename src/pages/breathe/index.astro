---
import { Image } from 'astro:assets';
import BreatheLayout from '@/layouts/BreatheLayout.astro';
import SeasonalIllustration from '@/components/breathe/SeasonalIllustration.astro';
import { getSeason, type Season } from '@/utils/season';
import leighForestPath from '@/assets/images/breathe/leigh-forest-path.jpg';
import leighTeaching from '@/assets/images/breathe/leigh-teaching-triangle.jpg';

// Single source of truth for this page's season. Change this one line to
// force a season (e.g. for testing): `const season: Season = 'winter';`
const season: Season = getSeason();

const sabbats = {
  spring: 'Beltane season',
  summer: 'Litha season',
  autumn: 'Mabon season',
  winter: 'Yule season',
} as const;

const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const initialLabel = `${cap(season)} · ${sabbats[season]}`;
---

<BreatheLayout
  title="Breathe — Leigh Bertelsen"
  description="Private sessions, seasonal gatherings, and the turning of the year, together."
  season={season}
>
  <div class="page">

    {/* ── Hero image ───────────────────────────────────────── */}
    <div class="hero-image-wrap">
      <Image
        src={leighForestPath}
        alt="A forest path in autumn outside Copenhagen"
        widths={[800, 1200, 1600]}
        sizes="100vw"
        class="hero-image"
      />
    </div>

    <section class="hero" aria-label="Welcome">
      {/* Eyebrow is a direct child of .hero (not inside .hero-text) so the
          mobile grid can place it inline with the illustration icon. */}
      <span class="season-eyebrow" data-season-eyebrow>{initialLabel}</span>

      <div class="hero-illustration">
        <SeasonalIllustration season={season} size={140} />
      </div>

      <div class="hero-text">
        <h1 class="headline">Come as you are.<br />Leave different.</h1>
        <p class="subline">
          Private sessions, seasonal gatherings, and the turning of the year, together.
        </p>
      </div>
    </section>

    <Image
      src={leighTeaching}
      alt="Leigh Bertelsen teaching triangle pose outdoors at the Himalayan Institute"
      widths={[600, 1000]}
      sizes="(max-width: 768px) 100vw, 700px"
      class="practice-photo"
    />

    <section class="offer" aria-label="Practice and gather">
      <h2 class="sr-only">Practice and gather</h2>

      <article class="card">
        <span class="card-label">practice together</span>
        <h3 class="card-title">Private sessions</h3>
        <p class="card-body">
          One-to-one sessions online, built around where you are and what you need. I teach
          Yin, Vinyasa, Hatha, Restorative, Yoga Nidra, and Gentle yoga, alongside Ayurvedic
          guidance, meditation, and tarot, or a combination of whatever feels right. We start
          with a conversation to work out what makes sense. Sessions can be combined with
          coaching if that feels useful.
        </p>
        {/* Entity-encoded mailto: leigh.bertelsen@gmail.com */}
        <a class="card-link" href="&#109;&#97;&#105;&#108;&#116;&#111;&#58;&#108;&#101;&#105;&#103;&#104;&#46;&#98;&#101;&#114;&#116;&#101;&#108;&#115;&#101;&#110;&#64;&#103;&#109;&#97;&#105;&#108;&#46;&#99;&#111;&#109;">get in touch</a>
      </article>

      <article class="card">
        <span class="card-label">gather</span>
        <h3 class="card-title">Seasonal circles</h3>
        <p class="card-body">
          Online gatherings marking the Wheel of the Year, from Imbolc to Samhain and the
          solstices and equinoxes in between. Open to all. Rooted in ritual, held with care.
          Join the list to hear when the next one is coming.
        </p>
        {/* Entity-encoded mailto: leigh.bertelsen@gmail.com */}
        <a class="card-link" href="&#109;&#97;&#105;&#108;&#116;&#111;&#58;&#108;&#101;&#105;&#103;&#104;&#46;&#98;&#101;&#114;&#116;&#101;&#108;&#115;&#101;&#110;&#64;&#103;&#109;&#97;&#105;&#108;&#46;&#99;&#111;&#109;">join the list</a>
      </article>
    </section>

    <section class="newsletter" aria-label="Stay connected">
      <p class="news-heading">Want to know when the next circle is?</p>
      <p class="news-sub">I send word when something is happening, and occasionally write about the season we're in. No noise, just signal and seasons.</p>
      <form class="news-form" onsubmit="event.preventDefault()">
        <label class="sr-only" for="news-email">Email address</label>
        <input id="news-email" type="email" placeholder="your@email" autocomplete="email" />
        <button type="submit">subscribe</button>
      </form>
    </section>
  </div>
</BreatheLayout>

<script>
  // Re-sync the season eyebrow with <html data-season> on load and soft nav.
  const sabbats: Record<string, string> = {
    spring: 'Beltane season',
    summer: 'Litha season',
    autumn: 'Mabon season',
    winter: 'Yule season',
  };
  function syncEyebrow() {
    const el = document.querySelector<HTMLElement>('[data-season-eyebrow]');
    if (!el) return;
    const s = document.documentElement.dataset.season;
    if (!s || !sabbats[s]) return;
    el.textContent = `${s.charAt(0).toUpperCase()}${s.slice(1)} · ${sabbats[s]}`;
  }
  syncEyebrow();
  document.addEventListener('astro:page-load', syncEyebrow);
</script>

<style>
  /* ── photos ──────────────────────────────── */
  .hero-image-wrap {
    width: 100%;
    max-width: 800px;
    margin: 0 auto 2.5rem;
    border-radius: 8px;
    overflow: hidden;
  }
  .hero-image {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16/9;
    object-fit: cover;
    object-position: center 30%;
  }

  .practice-photo {
    width: 100%;
    max-width: 700px;
    height: auto;
    border-radius: 8px;
    display: block;
    margin: 2rem auto;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .page {
    max-width: 800px;
    margin-inline: auto;
    padding: 6rem 2rem 4rem;
  }

  /* ── hero ────────────────────────────────── */
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "eyebrow illust"
      "text    illust";
    column-gap: 2rem;
    align-items: start;
  }
  .hero-text { grid-area: text; max-width: 56ch; }
  .hero-illustration { grid-area: illust; }

  .season-eyebrow {
    grid-area: eyebrow;
    display: inline-block;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
  }

  .headline {
    font-family: var(--font-serif-breathe);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(48px, 7vw, 72px);
    line-height: 1.1;
    color: var(--color-text-primary);
    margin: 0;
  }

  .subline {
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-style: normal;
    font-size: clamp(15px, 2vw, 18px);
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 1.5rem 0 0;
    max-width: 48ch;
  }

  .hero-illustration {
    opacity: 0.35;
    flex-shrink: 0;
    align-self: start;
    padding-top: 0.5rem;
  }

  /* ── offer ───────────────────────────────── */
  .offer {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-top: 3.5rem;
  }

  .card {
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-label {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .card-title {
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-style: normal;
    font-size: 22px;
    color: var(--color-text-primary);
    margin: 0;
  }

  .card-body {
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .card-link {
    margin-top: auto;
    padding-top: 0.75rem;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 13px;
    font-style: italic;
    color: var(--color-accent);
    text-decoration: none;
    align-self: flex-start;
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0% 100%;
    background-repeat: no-repeat;
    background-size: 0% 1px;
    transition: background-size 350ms ease;
  }
  .card-link:hover { background-size: 100% 1px; }

  /* ── newsletter ──────────────────────────── */
  .newsletter {
    margin-top: 3.5rem;
    margin-inline: calc(-1 * 2rem);
    background: var(--color-surface);
    border-top: 0.5px solid var(--color-border);
    padding: 2rem;
    text-align: center;
  }

  .news-heading {
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-style: italic;
    font-size: 20px;
    color: var(--color-text-primary);
    margin: 0;
  }

  .news-sub {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 13px;
    color: var(--color-text-secondary);
    margin: 0.5rem 0 1.25rem;
  }

  .news-form {
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }

  .news-form input {
    font-family: var(--font-sans);
    font-size: 13px;
    padding: 0.5rem 0.75rem;
    border: 0.5px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-bg);
    color: var(--color-text-primary);
    min-width: 220px;
  }
  .news-form input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .news-form button {
    font-family: var(--font-sans);
    font-size: 13px;
    font-style: italic;
    padding: 0.5rem 1rem;
    border: 1px solid color-mix(in oklch, var(--color-accent) 40%, transparent);
    border-radius: 6px;
    background: transparent;
    color: var(--color-accent);
    cursor: pointer;
    background-image: linear-gradient(color-mix(in oklch, var(--color-accent) 12%, transparent), color-mix(in oklch, var(--color-accent) 12%, transparent));
    background-position: 0% 100%;
    background-repeat: no-repeat;
    background-size: 0% 100%;
    transition: background-size 350ms ease;
  }
  .news-form button:hover { background-size: 100% 100%; }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  /* ── mobile ───────────────────────────────── */
  @media (max-width: 767px) {
    .page { padding: 5rem 1.5rem 6rem; }

    /* Icon + eyebrow share the first row; headline + subline span full
       width below. Trims a full row of vertical space vs stacking them. */
    .hero {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        "illust  eyebrow"
        "text    text";
      column-gap: 0.75rem;
      row-gap: 1rem;
      align-items: center;
    }
    .hero-illustration {
      grid-area: illust;
      /* Smaller, quieter on mobile — less visual noise. */
      opacity: 0.25;
    }
    .season-eyebrow {
      grid-area: eyebrow;
      /* No bottom margin needed — row-gap handles the space below. */
      margin-bottom: 0;
      align-self: center;
    }
    .hero-text { grid-area: text; }

    /* Override the 140px size set via the SeasonalIllustration prop. */
    .hero-illustration :global(svg) {
      width: 80px;
      height: 80px;
    }
    .offer {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .newsletter {
      margin-inline: calc(-1 * 1.5rem);
      padding: 1.5rem;
    }
  }
</style>
