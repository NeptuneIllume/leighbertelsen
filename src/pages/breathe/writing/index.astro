---
import BreatheLayout from '@/layouts/BreatheLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => data.world === 'breathe');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---

<BreatheLayout
  title="Writing on Yoga & Practice | Leigh Bertelsen"
  description="Essays on yoga, contemplative practice, and the language of teaching."
>
  <div class="placeholder">
    <h1 class="page-title">From the writing</h1>

    {posts.length === 0 ? (
      <p class="empty">Words for the season, when the season calls for them.</p>
    ) : (
      <ol class="post-list" role="list">
        {posts.map((post, i) => (
          <li class:list={['post-item', { 'has-divider': i > 0 }]}>
            <time class="post-date" datetime={post.data.date.toISOString()}>
              {fmt(post.data.date)}
            </time>
            <h2 class="post-title">
              <a href={`/blog/${post.slug}`}>{post.data.title}</a>
            </h2>
            <p class="post-excerpt">{post.data.excerpt}</p>
            <a class="post-link" href={`/blog/${post.slug}`}>Read →</a>
          </li>
        ))}
      </ol>
    )}
  </div>
</BreatheLayout>

<style>
  .placeholder {
    max-width: 800px;
    margin-inline: auto;
    padding: 6rem 2rem 4rem;
  }
  @media (max-width: 767px) {
    .placeholder { padding: 5rem 1.5rem 6rem; }
  }

  .page-title {
    font-family: var(--font-serif-breathe);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(36px, 5vw, 52px);
    line-height: 1.15;
    color: var(--color-text-primary);
    margin: 0 0 3rem;
  }

  .empty {
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-style: italic;
    font-size: 16px;
    color: var(--color-text-secondary);
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    padding: 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .post-item.has-divider {
    border-top: 0.5px solid var(--color-border);
  }

  .post-date {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 11px;
    color: var(--color-text-secondary);
    letter-spacing: 0.04em;
  }

  .post-title {
    margin: 0;
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-style: italic;
    font-size: 22px;
    color: var(--color-text-primary);
  }
  .post-title a {
    color: inherit;
    text-decoration: none;
    transition: color 200ms ease;
  }
  .post-title a:hover { color: var(--color-accent); }

  .post-excerpt {
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0.25rem 0 0;
    max-width: 65ch;
  }

  .post-link {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 13px;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: 0.25rem;
    align-self: flex-start;
    transition: opacity 200ms ease;
  }
  .post-link:hover { opacity: 0.75; }
</style>
