---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Sigil from '@/components/ui/Sigil.astro';
import { getCollection } from 'astro:content';
import leighSketching from '@/assets/images/personal/leigh-sketching-nepal.jpg';
import leighPokhara from '@/assets/images/personal/leigh-pokhara-overlook.jpg';

// Personal posts — empty gracefully if none exist.
const allPosts = await getCollection('posts', ({ data }) => data.world === 'personal');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });

const interests = [
  { emoji: '🧶', label: 'Knitting',   desc: 'Mostly socks. Always a project on the needles.' },
  { emoji: '🌱', label: 'Gardening',  desc: 'A small garden in Herlev. Vegetables, herbs, and optimism.' },
  { emoji: '📚', label: 'Reading',    desc: 'Fantasy, history, and anything about how people work.' },
  { emoji: '🌙', label: 'The Wheel',  desc: 'Marking the seasons. Samhain is a favourite.' },
  { emoji: '🧘', label: 'Practice',   desc: 'Yoga off the clock. Just moving, no teaching.' },
  { emoji: '✍️',  label: 'Writing',   desc: 'Sometimes words for their own sake.' },
];
---

<BaseLayout
  title="The Garden — Leigh Bertelsen"
  description="You found the garden."
  theme="membrane"
  footerHint="breathe in, breathe out"
  footerTarget="/"
>
  {/* Suppress default header — personal page has its own sigil. */}
  <Fragment slot="header" />

  <div class="garden">
    <a href="/" class="sigil-home" aria-label="Back to the beginning">
      <Sigil size={20} />
    </a>

    <section class="intro">
      <h1 class="heading">You found the garden.</h1>
      <p class="sub">
        This part isn't for everyone.<br />
        But since you're here…
      </p>
    </section>

    <section class="interests" aria-label="Interests">
      <ul class="grid" role="list">
        {interests.map((item) => (
          <li class="card">
            <span class="emoji" aria-hidden="true">{item.emoji}</span>
            <span class="label">{item.label}</span>
            <span class="desc">{item.desc}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="photo-strip" aria-label="Glimpses">
      <Image src={leighSketching}
        alt="Leigh sketching watercolours at a lakeside table in Nepal"
        widths={[400, 600]} sizes="33vw"
        class="strip-photo" />
      <Image src={leighPokhara}
        alt="Leigh overlooking Pokhara city and lake from a hilltop"
        widths={[400, 600]} sizes="33vw"
        class="strip-photo strip-photo-right" />
    </section>

    {posts.length > 0 && (
      <section class="writing" aria-label="Writing">
        <h2 class="writing-heading">From the notebook</h2>
        <ol class="post-list" role="list">
          {posts.map((post, i) => (
            <li class:list={['post-item', { 'has-divider': i > 0 }]}>
              <time class="post-date" datetime={post.data.date.toISOString()}>
                {fmt(post.data.date)}
              </time>
              <h3 class="post-title">
                <a href={`/blog/${post.slug}`}>{post.data.title}</a>
              </h3>
              <p class="post-excerpt">{post.data.excerpt}</p>
            </li>
          ))}
        </ol>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  /* ── page shell ──────────────────────────────── */
  .garden {
    background: #F5F0E8;
    color: #2C2416;
    min-height: 100dvh;
    max-width: 720px;
    margin-inline: auto;
    padding: 4rem 2rem 2rem;
    font-family: var(--font-sans);
  }
  @media (max-width: 767px) {
    .garden { padding: 3rem 1.5rem 1.5rem; }
  }

  /* ── sigil ───────────────────────────────────── */
  .sigil-home {
    display: inline-flex;
    color: #8B6914;
    margin-bottom: 3rem;
    transition: opacity 200ms ease;
  }
  .sigil-home:hover { opacity: 0.7; }

  /* ── intro ───────────────────────────────────── */
  .intro {
    margin-bottom: 3rem;
  }
  .heading {
    font-family: var(--font-serif-breathe);
    font-weight: 300;
    font-style: italic;
    font-size: 36px;
    line-height: 1.2;
    color: #2C2416;
    margin: 0 0 0.75rem;
  }
  .sub {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 14px;
    line-height: 1.7;
    color: #7A6040;
    margin: 0;
  }

  /* ── interests grid ──────────────────────────── */
  .interests { margin-bottom: 4rem; }
  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 640px) {
    .grid { grid-template-columns: 1fr; }
  }

  .card {
    background: #EDE5D4;
    border: 0.5px solid #D4C8B0;
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .emoji {
    font-size: 32px;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 13px;
    color: #2C2416;
  }
  .desc {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 12px;
    color: #7A6040;
    line-height: 1.5;
  }

  /* ── photo strip ────────────────────────────── */
  .photo-strip {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin: 2.5rem 0;
  }
  @media (max-width: 480px) {
    .photo-strip { grid-template-columns: 1fr; }
  }
  .strip-photo {
    width: 100%;
    height: auto;
    border-radius: 8px;
    aspect-ratio: 3/4;
    object-fit: cover;
  }
  .strip-photo-right {
    object-position: right center;
  }

  /* ── personal writing ────────────────────────── */
  .writing { margin-bottom: 3.5rem; }
  .writing-heading {
    font-family: var(--font-serif-breathe);
    font-weight: 300;
    font-style: italic;
    font-size: 22px;
    color: #2C2416;
    margin: 0 0 1.5rem;
  }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-item {
    padding: 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .post-item.has-divider { border-top: 0.5px solid #D4C8B0; }
  .post-date {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 11px;
    color: #7A6040;
    letter-spacing: 0.04em;
  }
  .post-title {
    margin: 0;
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-style: italic;
    font-size: 18px;
    color: #2C2416;
  }
  .post-title a {
    color: inherit;
    text-decoration: none;
  }
  .post-title a:hover { color: #8B6914; }
  .post-excerpt {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 13px;
    line-height: 1.6;
    color: #7A6040;
    margin: 0;
  }
</style>
