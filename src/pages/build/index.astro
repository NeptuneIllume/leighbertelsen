---
import BuildLayout from '@/layouts/BuildLayout.astro';

const heroQuote = {
  text: 'She not only thinks at a high level but also delivers concrete results.',
  name: 'Jesper Mårtensson',
  role: 'former manager, Netcompany Banking Services',
};

const quotes = [
  {
    text: 'She has a unique ability to see the big picture while being incredibly thorough and detail-oriented in her daily work. This combination makes her both reliable and highly effective.',
    name: 'Pernille Thyssen',
    role: 'Senior Test Specialist, Netcompany Banking Services',
  },
  {
    text: 'Finding a developer with a keen sense of design and user experience is very rare and important. I think Leigh is a diamond in the rough as far as developers are concerned. She brings more than programming to the table.',
    name: 'Ann Meneses',
    role: 'Senior Designer, Himalayan Institute',
  },
  {
    text: "I trust her because she took the time to understand me and my work. She did it all with love, and I really felt that.",
    name: 'Evey Kochanek',
    role: 'Nutritionist and Business Owner',
  },
  {
    text: "Her passion for accessibility isn't just talk either; she truly builds with everyone in mind.",
    name: 'Elvis Carlos Pesconi Junior',
    role: 'Senior Developer, Netcompany Banking Services',
  },
];

const experience = [
  {
    company: 'Netcompany Banking Services',
    role: 'Senior Web Developer, Platform and Website Lead',
    period: 'September 2023 to present · Copenhagen',
    body: `I'm part of the team building and evolving a core banking platform that spans more than 50 financial institutions across the Nordic region, touching the online banking experience of over 2 million end users. Within that, I led the company-wide accessibility initiative from start to finish: defining the WCAG 2.2 compliance standards, architecting and implementing automated accessibility testing into the Azure DevOps CI/CD pipeline at every stage from IDE to unit tests to integration tests to end-to-end to CI, training the team, and guiding implementation across all digital products. The goal was to make accessibility a required and painless part of how the team already works, and that's what it has become. Beyond that initiative, I consistently perform among the highest in the team across architecture, delivery, code quality, and mentoring.`,
  },
  {
    company: 'Neptune Illume',
    role: 'Founder and Senior Web Developer',
    period: 'June 2007 to present · Remote',
    body: `Full-stack web development and design studio serving clients across wellness, education, and nonprofit sectors. Services span user research, content strategy, UX/UI design, wireframing, build, database integration, and hosting, alongside email and social media marketing, SEO, brand development, and analytics. Selected clients include Rinchenshop.com (multilingual DE/EN Shopify store with event registration, GDPR-compliant analytics, and WordPress content feed), Yoga International, Chattra Yoga, Nikki Estrada, Pacific Yoga, and others across the wellness and education space.`,
  },
  {
    company: 'Himalayan Institute',
    role: 'Web Development Manager, Creative Services',
    period: 'October 2015 to January 2017 · Honesdale, PA',
    body: `Led the planning and execution of a complete rebuild of the Himalayan Institute's website and Global Humanitarian Projects website. Directed content, branding strategy, implementation, and QA testing across all web projects, working with the Creative Services department, department heads, and the broader community. Revitalised the branding of all digital and print materials with a new style guide based on customer-driven marketing strategy. Built front-end interfaces and data-driven interactive elements including the Wisdom Library subscription service. Also built the website for the Institute's health centre, PureRejuv, and ran technology training within the Creative Services department.`,
  },
  {
    company: 'Yoga International',
    role: 'Marketing Specialist',
    period: 'July 2020 to September 2021 · Remote',
    body: `Drove a 73% increase in paid memberships through data-driven course creation and conversion-focused email campaigns to an audience of 800,000 to 1,000,000 subscribers. Produced approximately 50 online courses in Contentful, built corresponding landing pages in HubSpot with A/B-tested copy and CTAs, and analysed acquisition and conversion data in Google Analytics to inform ongoing strategy. Role ended following company acquisition and restructuring.`,
  },
  {
    company: 'SystemArchitecture.NET',
    role: 'Software Developer and UX Consultant',
    period: 'August 2017 to January 2019 · Remote',
    body: `Built and evolved application and website platforms for multiple clients across full-stack .NET, C#, SQL, and PHP/WordPress. Designed user experiences, engaged with clients to collect conceptual framework and business needs, and led marketing and branding strategy projects.`,
  },
  {
    company: 'Bristol-Myers Squibb',
    role: 'Senior Developer, Marketing',
    period: 'November 2010 to May 2012 · Princeton, NJ',
    body: `Lead developer on BMStudio's first in-house touchscreen presentation, which the sales team described as the best presentation they had ever seen. Developed touchscreen closed-loop promotions for PC and iPad using Exploria's e-detailing platform, 3D graphics and animations, ActionScript 3, JavaScript, XHTML, and CSS.`,
  },
  {
    company: 'Health Advocate',
    role: 'Senior Interactive Developer, Marketing',
    period: 'August 2013 to October 2015 · Plymouth Meeting, PA',
    body: `Developed marketing websites, a custom blog, interactive tools, and animations, as well as established metric reporting for a healthcare benefits company.`,
  },
  {
    company: 'General Physics',
    role: 'Developer',
    period: 'May 2010 to October 2010 · Pottstown, PA',
    body: `Designed and developed custom eLearning solutions including GUI shells, web-based courses, simulations, online games, and quizzes. Developed style guides and templates.`,
  },
];
---

<BuildLayout
  title="Work — Leigh Bertelsen"
  description="Senior web developer with 17 years of experience across fintech, e-commerce, nonprofits, and wellness."
>
  <div class="page">

    {/* ── Hero ─────────────────────────────────────────────── */}
    <section class="hero" aria-label="Introduction">
      <p class="eyebrow">// senior web developer · principal-level · accessibility</p>

      <h1 class="headline">Building things that work for everyone.</h1>

      <p class="subline">
        17 years of full-stack experience across fintech, e-commerce, nonprofits,
        and wellness. I love getting a high-level overview of what a business needs
        and then running with it from planning to execution, because that amount of
        ownership and responsibility is where I do my best work.
      </p>
    </section>

    {/* ── Featured cards ───────────────────────────────────── */}
    <section class="featured" aria-label="Featured work">
      <h2 class="sr-only">Featured work</h2>

      <article class="card">
        <div class="card-ornament card-ornament--code" aria-hidden="true">
          <div class="code-excerpt">
            <div class="code-panel">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 600 140"
                width="100%"
                height="auto"
                role="presentation"
                aria-hidden="true"
                focusable="false"
                class="code-svg"
              >
                <text x="12" y="22"  font-family="'Fragment Mono', monospace" font-size="13" fill="var(--color-text-primary)">// CI: every PR runs axe-core against the</text>
                <text x="12" y="44"  font-family="'Fragment Mono', monospace" font-size="13" fill="var(--color-text-primary)">// component library before merge.</text>
                <text x="12" y="66"  font-family="'Fragment Mono', monospace" font-size="13" fill="var(--color-text-primary)">test('no a11y violations in production build', async () =&gt; &#123;</text>
                <text x="12" y="88"  font-family="'Fragment Mono', monospace" font-size="13" fill="var(--color-text-primary)">  const violations = await runAxe(app);</text>
                <text x="12" y="110" font-family="'Fragment Mono', monospace" font-size="13" fill="var(--color-text-primary)">  expect(violations).toEqual([]);</text>
                <text x="12" y="132" font-family="'Fragment Mono', monospace" font-size="13" fill="var(--color-text-primary)">&#125;);</text>
              </svg>
            </div>
          </div>
        </div>
        <p class="card-label">featured work</p>
        <h3 class="card-title">Accessibility implementation</h3>
        <p class="card-desc">
          Leading WCAG 2.2 AA compliance across a fintech platform,
          from audit to component library.
        </p>
        <a class="card-link" href="/build/projects">read case study</a>
      </article>

      <article class="card">
        <div class="card-ornament card-ornament--sigil" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 64 64"
            width="150"
            height="150"
            aria-hidden="true"
            role="presentation"
            class="sigil-centered"
          >
            <circle cx="32" cy="32" r="28" fill="none" stroke="currentColor" stroke-width="1" opacity="0.55" />
            <path d="M32 8 L54 44 L10 44 Z" fill="none" stroke="currentColor" stroke-width="1" opacity="0.85" />
            <circle cx="32" cy="34" r="10" fill="none" stroke="currentColor" stroke-width="1" />
            <circle cx="32" cy="34" r="1.6" fill="currentColor" />
          </svg>
        </div>
        <p class="card-label">built in public</p>
        <h3 class="card-title">leighbertelsen.com</h3>
        <p class="card-desc">
          Astro 5, GSAP, three worlds, one URL. The site you're on right now.
        </p>
        <a class="card-link" href="/build/projects">how it's built</a>
      </article>
    </section>

    {/* ── Current role ─────────────────────────────────────── */}
    <section class="section" aria-label="Current role">
      <p class="section-label">currently</p>
      <h2 class="section-title">Senior Web Developer, Platform and Website Lead</h2>
      <p class="section-meta">Netcompany Banking Services · Copenhagen · September 2023 to present</p>

      <dl class="stat-block" aria-label="Platform scale">
        <div class="stat">
          <dd class="stat-value">50+</dd>
          <dt class="stat-label">nordic financial institutions</dt>
        </div>
        <div class="stat">
          <dd class="stat-value">2M+</dd>
          <dt class="stat-label">end users on the platform</dt>
        </div>
      </dl>

      <p class="section-body">
        I'm part of the team building and evolving a core banking platform across the Nordic
        region. Within that, I led the company-wide
        accessibility initiative from start to finish: defining the WCAG 2.2 compliance
        standards, architecting and implementing automated accessibility testing into the
        Azure DevOps CI/CD pipeline at every stage from IDE to unit tests to integration
        tests to end-to-end to CI, training the team, and guiding implementation across
        all digital products. The goal was to make accessibility a required and painless
        part of how the team already works, and that's what it has become. Beyond that
        initiative, I consistently perform among the highest in the team across
        architecture, delivery, code quality, and mentoring.
      </p>
    </section>

    {/* ── For clients ──────────────────────────────────────── */}
    <section class="section" aria-label="For clients">
      <p class="section-label">for clients</p>
      <h2 class="section-title">
        You don't need to know how it works.<br class="title-break" /> You just need to know what you want.
      </h2>
      <p class="section-body">
        I've spent much of my career working with business owners, yoga teachers, authors,
        nonprofits, and wellness practitioners. People who had a clear sense of what they
        wanted their web presence to feel like but no idea how to get there technically.
        That's the gap I close. Tell me the vibe, the goals, the audience you're trying to
        reach, and I'll translate that into something that works beautifully, performs well,
        and actually sounds like you. The number one thing clients tell me afterward is that
        I delivered more than they expected, faster than they thought possible. That's not
        an accident. I have a knack for immediately gathering the information that matters,
        and I care deeply about people's time.
      </p>
      <p class="section-body">
        A recent example: <a class="inline-link" href="https://yogasoleil.dk" target="_blank" rel="noopener">yogasoleil.dk</a>,
        a site for a practitioner who does massage, yoga, and youth mentoring. She knew it
        was important to have a web presence but had no idea where to start technically. We
        worked through what her business needed, and what came out was a site that works as
        a real marketing tool, is easy for her to navigate and update, and genuinely sounds
        like her. We're still building on it together.
      </p>
    </section>

    {/* ── Recommendations ──────────────────────────────────── */}
    <section class="section" aria-label="Recommendations">
      <p class="section-label">what people say</p>

      {/* Hero pull-quote */}
      <div class="hero-pull-quote">
        <span class="hero-quote-glyph" aria-hidden="true">&ldquo;</span>
        <blockquote class="hero-quote-text">{heroQuote.text}</blockquote>
        <footer class="hero-quote-attr">
          <span class="hero-quote-name">— {heroQuote.name}</span>
          <span class="hero-quote-role">{heroQuote.role}</span>
        </footer>
      </div>

      <ul class="quotes-grid" role="list">
        {quotes.map((q) => (
          <li class="quote-card">
            <blockquote class="quote-text">"{q.text}"</blockquote>
            <footer class="quote-attr">
              <span class="quote-name">{q.name}</span>
              <span class="quote-role">{q.role}</span>
            </footer>
          </li>
        ))}
      </ul>
    </section>

    {/* ── Experience ───────────────────────────────────────── */}
    <section class="section" aria-label="Experience">
      <p class="section-label">experience</p>
      <ol class="timeline" role="list">
        {experience.map((e) => (
          <li class="timeline-entry">
            <p class="timeline-period">{e.period}</p>
            <h3 class="timeline-company">{e.company}</h3>
            <p class="timeline-role">{e.role}</p>
            <p class="timeline-body">{e.body}</p>
          </li>
        ))}
      </ol>
    </section>

    {/* ── Awards ───────────────────────────────────────────── */}
    <section class="section" aria-label="Awards">
      <p class="section-label">awards</p>
      <ul class="awards-list" role="list">
        <li class="award-item">
          <span class="award-year">2015</span>
          Platinum Hermes Creative Award, Category: Blog (overall)
        </li>
        <li class="award-item">
          <span class="award-year">2015</span>
          Gold Hermes Creative Award, Category: Pro Bono
        </li>
      </ul>
    </section>

    {/* ── Skills ───────────────────────────────────────────── */}
    <section class="section" aria-label="Skills and tools">
      <p class="section-label">skills and tools</p>
      <dl class="skill-groups">
        <div class="skill-group">
          <dt class="skill-group-label">frontend</dt>
          <dd class="skill-group-chips">
            <ul class="tags">
              <li class="tag">React</li>
              <li class="tag">TypeScript</li>
              <li class="tag">Next.js</li>
              <li class="tag">Astro</li>
              <li class="tag">HTML5</li>
              <li class="tag">CSS3</li>
              <li class="tag">Tailwind</li>
            </ul>
          </dd>
        </div>
        <div class="skill-group">
          <dt class="skill-group-label">backend &amp; data</dt>
          <dd class="skill-group-chips">
            <ul class="tags">
              <li class="tag">Node</li>
              <li class="tag">PHP</li>
              <li class="tag">C# / ASP.NET</li>
              <li class="tag">SQL</li>
              <li class="tag">REST</li>
              <li class="tag">GraphQL</li>
            </ul>
          </dd>
        </div>
        <div class="skill-group">
          <dt class="skill-group-label">platform &amp; a11y</dt>
          <dd class="skill-group-chips">
            <ul class="tags">
              <li class="tag">Azure DevOps</li>
              <li class="tag">CI/CD</li>
              <li class="tag">WCAG 2.2</li>
              <li class="tag">Accessibility</li>
            </ul>
          </dd>
        </div>
        <div class="skill-group">
          <dt class="skill-group-label">cms &amp; analytics</dt>
          <dd class="skill-group-chips">
            <ul class="tags">
              <li class="tag">Optimizely</li>
              <li class="tag">Google Analytics</li>
              <li class="tag">Contentful</li>
              <li class="tag">HubSpot</li>
              <li class="tag">Magento</li>
              <li class="tag">WordPress</li>
              <li class="tag">Shopify</li>
              <li class="tag">Liquid</li>
            </ul>
          </dd>
        </div>
      </dl>
    </section>

  </div>
</BuildLayout>

<style>
  /* ── page wrapper ──────────────────────── */
  .page {
    max-width: 860px;
    margin-inline: auto;
    padding: 6rem 2rem 5rem;
  }
  @media (max-width: 767px) {
    .page {
      max-width: 100%;
      padding: 5rem 1.25rem 6rem;
    }
    .featured { gap: 1rem; }
  }

  /* ── hero ─────────────────────────────── */
  .hero {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-accent);
    margin: 0;
  }
  .headline {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin: 0;
  }
  .subline {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(15px, 2vw, 17px);
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 65ch;
  }

  /* ── card ornaments (filled image areas) ── */
  .card-ornament {
    width: 100%;
    background: var(--color-surface);
    border-radius: 6px;
    border: 0.5px solid var(--color-border);
    margin-bottom: 0.75rem;
    position: relative;
  }

  /* Code fragment variant — height follows content */
  .card-ornament--code {
    overflow: hidden;
  }
  .code-excerpt {
    width: 100%;
  }
  .code-panel {
    background-color: var(--color-surface);
    padding: 1.25rem 1.5rem;
    border-radius: 4px;
  }
  .code-svg {
    display: block;
  }

  /* Sigil variant — fixed height, centered */
  .card-ornament--sigil {
    aspect-ratio: 16/9;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .sigil-centered {
    color: color-mix(in srgb, var(--color-accent) 22%, transparent);
    user-select: none;
    pointer-events: none;
    flex-shrink: 0;
  }

  /* ── featured cards ───────────────────── */
  .featured {
    margin-top: 3.5rem;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1.25rem;
  }
  @media (max-width: 640px) {
    .featured { grid-template-columns: 1fr; }
  }

  .card {
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .card-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-accent);
    margin: 0;
  }
  .card-title {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 18px;
    color: var(--color-text-primary);
    margin: 0;
  }
  .card-desc {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
  }
  .card-link {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 12px;
    letter-spacing: 0.02em;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: 0.25rem;
  }
  .card-link::before { content: '[ '; }
  .card-link::after  { content: ' ]'; }
  .card-link:hover { opacity: 0.75; }

  /* ── shared section chrome ────────────── */
  .section {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 0.5px solid var(--color-border);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 1rem;
  }

  .section-title {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(18px, 2.5vw, 22px);
    line-height: 1.3;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
  }
  .title-break { display: inline; }
  @media (max-width: 560px) {
    .title-break { display: none; }
  }

  .section-meta {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--color-text-secondary);
    margin: 0 0 1.25rem;
  }

  /* ── stat block ───────────────────────── */
  .stat-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    border-top: 1px solid color-mix(in srgb, var(--color-text) 15%, transparent);
    padding-top: 2rem;
    margin: 2.5rem 0;
    padding-left: 0;
  }
  @media (max-width: 640px) {
    .stat-block {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .stat-value {
    font-family: var(--font-sans);
    font-size: clamp(36px, 4vw, 56px);
    font-weight: 400;
    line-height: 1.05;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem 0;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 13px;
    text-transform: lowercase;
    letter-spacing: 0.02em;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
    margin: 0;
  }

  .section-body {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(14px, 1.8vw, 15px);
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin: 0 0 1em;
    max-width: 65ch;
  }
  .section-body:last-child { margin-bottom: 0; }

  .inline-link {
    color: var(--color-accent);
    text-decoration: none;
  }
  .inline-link:hover { text-decoration: underline; }

  /* ── hero pull-quote ────────────────────── */
  .hero-pull-quote {
    position: relative;
    padding: 3.5rem 0;
    margin-bottom: 2.5rem;
  }

  .hero-quote-glyph {
    position: absolute;
    top: 2.5rem;
    left: -0.25rem;
    font-family: var(--font-sans);
    font-size: 120px;
    line-height: 1;
    color: var(--color-text);
    opacity: 0.15;
    user-select: none;
    pointer-events: none;
    aria-hidden: true;
  }

  .hero-quote-text {
    font-family: var(--font-sans);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 1.25;
    color: var(--color-text);
    max-width: 35rem;
    margin: 0;
    padding-left: 0.5rem;
  }

  .hero-quote-attr {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-top: 1.5rem;
    padding-left: 0.5rem;
  }

  .hero-quote-name {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 400;
    text-transform: lowercase;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
  }

  .hero-quote-role {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 400;
    text-transform: lowercase;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
  }

  /* ── recommendations ──────────────────── */
  .quotes-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 640px) {
    .quotes-grid { grid-template-columns: 1fr; }
  }

  .quote-card {
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .quote-text {
    font-family: var(--font-sans);
    font-weight: 300;
    font-style: italic;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-text-primary);
    margin: 0;
  }

