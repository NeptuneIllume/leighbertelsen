---
import BuildLayout from '@/layouts/BuildLayout.astro';
import Sigil from '@/components/ui/Sigil.astro';
---

<BuildLayout title="About — Build — Leigh Bertelsen">
  <div class="placeholder">
    <h1>About</h1>

    <div class="easter-egg-area">
      <button class="egg-sigil" aria-label="Sigil" data-egg-sigil>
        <Sigil size={28} />
      </button>
      <p class="hint">linger here a moment</p>
    </div>
  </div>
</BuildLayout>

<script>
  import gsap from 'gsap';

  function init() {
    const btn = document.querySelector<HTMLElement>('[data-egg-sigil]');
    if (!btn) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function navigate() {
      if (prefersReduced) {
        window.location.assign('/personal');
        return;
      }
      gsap.timeline({ onComplete: () => window.location.assign('/personal') })
        .to(btn, { scale: 1.15, duration: 0.2, ease: 'power2.out' })
        .to(btn, { scale: 1,    duration: 0.2, ease: 'power2.in' });
    }

    // Desktop — slow double-click (100–600ms between clicks)
    let lastClick = 0;
    btn.addEventListener('click', () => {
      const now = Date.now();
      const gap = now - lastClick;
      lastClick = now;
      if (gap >= 100 && gap <= 600) navigate();
    });

    // Mobile — long press (600ms)
    let pressTimer: ReturnType<typeof setTimeout> | null = null;
    btn.addEventListener('touchstart', (e) => {
      e.preventDefault();
      pressTimer = setTimeout(navigate, 600);
    }, { passive: false });
    btn.addEventListener('touchend', () => {
      if (pressTimer) { clearTimeout(pressTimer); pressTimer = null; }
    });
    btn.addEventListener('touchmove', () => {
      if (pressTimer) { clearTimeout(pressTimer); pressTimer = null; }
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .placeholder {
    max-width: 860px;
    margin-inline: auto;
    padding: 6rem 2rem 4rem;
  }
  @media (max-width: 767px) {
    .placeholder { padding: 5rem 1.5rem 6rem; }
  }
  h1 {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(36px, 5vw, 56px);
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin: 0 0 4rem;
  }

  /* ── easter egg ── */
  .easter-egg-area {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    margin-top: 6rem;
  }
  .egg-sigil {
    background: none;
    border: none;
    padding: 0.5rem;
    margin: -0.5rem;
    cursor: pointer;
    color: var(--color-tab-dim);
    display: inline-flex;
    transition: color 200ms ease;
    transform-origin: center;
  }
  .egg-sigil:hover { color: var(--color-accent); }
  .hint {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-tab-dim);
    opacity: 0.6;
    margin: 0;
    user-select: none;
  }
</style>
