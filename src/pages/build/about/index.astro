---
import BuildLayout from '@/layouts/BuildLayout.astro';
import Sigil from '@/components/ui/Sigil.astro';
import { getLastModified } from '@/utils/lastModified';
import JsonLd from '@/components/ui/JsonLd.astro';
import { personSchema } from '@/utils/personSchema';

const lastEdited = getLastModified('src/pages/build/about/index.astro');

const education = [
  {
    institution: 'Drexel University',
    detail: 'B.S. Digital Media, Fine Art Minor, Graduated with Honors',
    period: 'September 2005 to June 2009 · Philadelphia, PA',
    description: 'A liberal arts curriculum grounded in 3D modelling and animation, human-computer interaction, web development, programming principles, design, new media theory, and photo, audio, and video processing. This is where I learned to think about technology and design as inseparable disciplines.',
  },
  {
    institution: 'She Leads',
    detail: 'ICF-Accredited Coach Certification',
    period: '',
    description: 'Coach training grounded in ICF methodology, feminine leadership, somatic and nervous system approaches, and self-worth as a foundation for change. This training deepened what I already knew from years of yoga and contemplative study and gave it a practical coaching framework.',
  },
  {
    institution: 'FreeCodeCamp',
    detail: 'Responsive Web Design · JavaScript Algorithms and Data Structures · Front End Libraries',
    period: 'January to March 2020',
    description: '',
  },
  {
    institution: 'Marie Forleo',
    detail: 'B-School, Marketing Certification · The Copy Cure, Copywriting Certification',
    period: 'March to June 2020',
    description: '',
  },
];
---

<BuildLayout
  title="About | Build | Leigh Bertelsen"
  description="Senior web developer based in Copenhagen, building for fintech, e-commerce, nonprofits, and wellness for 17 years."
>
  <JsonLd schema={personSchema} />
  <div class="page">

    <h1 class="headline">Calm, focused, kind.</h1>

    {/* ── Intro ──────────────────────────────────────────── */}
    <section class="intro" aria-label="Introduction">
      <p class="body">That's how colleagues describe me. I try to deserve it.</p>
      <p class="body">
        I'm a senior web developer based in Copenhagen, and I've been building things on
        the internet for 17 years, across fintech, e-commerce, nonprofits, wellness,
        healthcare, and education. I genuinely love this work. Getting a high-level overview
        of what a business needs and then running with it from planning to execution, that's
        where I'm happiest and where I do my best work.
      </p>
      <p class="body">
        Right now I'm at Skandinavisk Data Center, where I'm part of the team building
        and evolving a core banking platform across 50+ Nordic financial institutions. Within
        that I led the company-wide accessibility initiative, which is something I'm
        particularly proud of, both for the reach of its impact and for how we integrated it
        into the team's workflow without adding friction. Before that I spent years
        freelancing through my studio Neptune Illume, working with clients in yoga,
        meditation, nonprofit, and wellness, which gave me a foundation in listening
        carefully, moving fast, and building things that actually sound and feel like the
        people they're for.
      </p>
    </section>

    {/* ── Working with me ────────────────────────────────── */}
    <section class="section" aria-label="Working with me">
      <p class="section-label">working with me</p>
      <p class="body">
        I'm calm, focused, and I care a lot about people's time. Colleagues consistently
        describe me as someone who lifts the quality and mood of a team without making a big
        deal of it. I think that's because I genuinely enjoy the work and enjoy the people I
        do it with.
      </p>
      <p class="body">
        I thrive at being an expert in tandem with helping others. That means I'm as
        comfortable presenting architectural decisions to a CTO as I am walking a first-time
        client through what a website actually needs to do for their business. I find working
        with non-technical people particularly rewarding, because what I do genuinely
        seems like magic to them, which never gets old.
      </p>
      <p class="body">
        When I say something, I've usually already thought it through. I process internally
        before I speak, which means my contributions tend to be considered rather than
        reactive, and I plan for the long term rather than the next sprint.
      </p>
    </section>

    {/* ── Beyond the work ────────────────────────────────── */}
    <section class="section" aria-label="Beyond the work">
      <p class="section-label">beyond the work</p>
      <p class="body">
        I'm also a 500-hour certified yoga teacher, an ICF-accredited coach, and someone who
        has spent a significant part of her life in serious study of contemplative practice,
        from monasteries in Nepal and India to academic Buddhist studies in Austria. I
        mention this not because it's unusual, but because it's part of how I approach
        everything: with patience, with genuine attention, and with a long view. If you're
        curious about that side of things, you can find it at{' '}
        <a class="inline-link" href="/breathe">Breathe</a> and{' '}
        <a class="inline-link" href="/be">Be</a>.
      </p>
      <p class="body">
        I live by a forest outside of Copenhagen with my husband Mads and our dog Nighteyes.
        I have a small garden, I'm a maker in the broadest sense of the word, from building
        things with Raspberry Pi to crochet to watercolour, and I mark the turning of the year.
      </p>
    </section>

    {/* ── Education ──────────────────────────────────────── */}
    <section class="section" aria-label="Education">
      <p class="section-label">education</p>
      <ul class="edu-list" role="list">
        {education.map((e) => (
          <li class="edu-entry">
            <span class="edu-institution">{e.institution}</span>
            <span class="edu-detail">{e.detail}</span>
            {e.period && <span class="edu-period">{e.period}</span>}
            {e.description && <span class="edu-description">{e.description}</span>}
          </li>
        ))}
      </ul>
    </section>

    {/* ── Contact ────────────────────────────────────────── */}
    <section class="section" aria-label="Get in touch">
      <p class="section-label">contact</p>
      <p class="body">
        If you're looking for a senior developer with depth in accessibility, platform
        thinking, and a genuine interest in the people on the other end of the screen, I'd
        love to hear from you.
      </p>
      {/* HTML entity encoding — reduces harvesting by email spam bots
          while remaining fully functional for human visitors and screen
          readers. Entity-encoded mailto link. */}
      <a class="email-cta" href="&#109;&#97;&#105;&#108;&#116;&#111;&#58;&#104;&#101;&#108;&#108;&#111;&#64;&#108;&#101;&#105;&#103;&#104;&#98;&#101;&#114;&#116;&#101;&#108;&#115;&#101;&#110;&#46;&#99;&#111;&#109;">
        [ get in touch ]
      </a>
    </section>

  </div>

  <footer class="site-footer" slot="footer">
    {lastEdited && (
      <p class="last-updated">last edited {lastEdited}</p>
    )}
    <button class="footer-signature" data-egg-sigil data-egg-target="/personal">
      <Sigil size={20} />
      <span class="footer-text">linger here a moment</span>
    </button>
  </footer>
</BuildLayout>

<style>
  .page {
    max-width: 720px;
    margin-inline: auto;
    padding: 6rem 2rem 5rem;
  }
  @media (max-width: 767px) {
    .page { padding: 5rem 1.5rem 6rem; }
  }

  /* ── shared body text ─────────────────── */
  .body {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 17px;
    line-height: 1.65;
    color: var(--color-text-primary);
    margin: 0 0 1.25em;
    max-width: 35rem;
  }
  .body:last-of-type { margin-bottom: 0; }

  /* ── section chrome ───────────────────── */
  .headline {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin-bottom: 1.25rem;
  }

  .section {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 0.5px solid var(--color-border);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 1.25rem;
  }

  .inline-link {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-decoration-color: color-mix(in srgb, currentColor 50%, transparent);
    text-underline-offset: 0.15em;
  }
  .inline-link:hover {
    text-decoration-color: currentColor;
  }

  /* ── education ────────────────────────── */
  .edu-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .edu-entry {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .edu-institution {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 14px;
    color: var(--color-text-primary);
  }

  .edu-detail {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-text-secondary);
  }

  .edu-period {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--color-text-secondary);
    margin-top: 0.1rem;
  }

  .edu-description {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 13px;
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin-top: 0.5rem;
  }

  /* ── contact ──────────────────────────── */
  .email-cta {
    display: inline-block;
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 12px;
    letter-spacing: 0.02em;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: 1rem;
    transition: opacity 200ms ease;
  }
  .email-cta:hover { opacity: 0.75; }

  /* ── footer ───────────────────────────── */
  .site-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 3rem 1.5rem 2rem;
  }  .footer-signature {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: none;
    border: none;
    padding: 0.5rem;
    margin: -0.5rem;
    cursor: pointer;
    color: color-mix(in srgb, var(--color-text) 45%, transparent);
    transition: color 200ms ease;
    transform-origin: center;
  }
  .footer-signature:hover {
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
  }
  .footer-text {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 300;
    font-style: italic;
    letter-spacing: 0.02em;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
    user-select: none;
  }  .last-updated {
    font-weight: 400;
    font-size: 12px;
    color: var(--color-tab-dim);
    margin: 0;
  }
</style>
