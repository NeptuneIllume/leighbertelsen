---
interface Props {
  size?: number;
  class?: string;
  title?: string;
  colorized?: boolean;
}

const { size = 32, class: className, title = 'Leigh Bertelsen', colorized = false } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 64 64"
  width={size}
  height={size}
  role="img"
  aria-label={title}
  class:list={['sigil', className]}
  data-sigil
>
  <title>{title}</title>
  {/* Placeholder sigil: overlapping mark hinting at three worlds + a hidden fourth.
      Replace with final artwork; keep [data-sigil] hook for the easter-egg interaction. */}
  <circle cx="32" cy="32" r="28" fill="none" stroke="currentColor" stroke-width="1" opacity="0.55" />
  <path d="M32 8 L54 44 L10 44 Z" fill="none" stroke="currentColor" stroke-width="1" opacity="0.85" />
  <circle cx="32" cy="34" r="10" fill="none" stroke="currentColor" stroke-width="1" />
  <circle cx="32" cy="34" r="1.6" fill="currentColor" data-sigil-core />
</svg>

<style>
  .sigil {
    color: var(--color-accent, var(--color-text, currentColor));
    display: inline-block;
    vertical-align: middle;
  }
</style>
