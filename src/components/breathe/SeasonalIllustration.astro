---
import { Image } from 'astro:assets';
import { getSeason, type Season } from '@/utils/season';
import spring from '@/assets/images/breathe/botanical-spring-crocus.png';
import summer from '@/assets/images/breathe/botanical-summer-peony.png';
import autumn from '@/assets/images/breathe/botanical-autumn-rudbeckia.png';
import winter from '@/assets/images/breathe/botanical-winter-hellebore.png';

interface Props {
  season?: Season;
}

const { season = getSeason() } = Astro.props;
const plate = {
  spring: { img: spring, label: 'Crocus mæsiacus' },
  summer: { img: summer, label: 'Pæonia tenuifolia' },
  autumn: { img: autumn, label: 'Rudbeckia hirta' },
  winter: { img: winter, label: 'Helleborus niger' },
}[season];
---

<figure class="botanical-plate" aria-hidden="true">
  <Image src={plate.img} alt="" widths={[220, 360]} sizes="clamp(220px, 24vw, 360px)" />
</figure>

<style>
  .botanical-plate {
    filter: none;
    width: clamp(220px, 24vw, 360px);
    margin: 0;
    padding: 0;
  }
  .botanical-plate img {
    width: 100%;
    height: auto;
    display: block;
    filter: none;
  }
</style>

