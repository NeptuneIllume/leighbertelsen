---
import { ClientRouter } from 'astro:transitions';
import Sigil from '@/components/ui/Sigil.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  theme?: 'membrane' | 'build' | 'breathe' | 'be' | 'personal';
  season?: 'spring' | 'summer' | 'autumn' | 'winter';
  footerHint?: string;
  footerTarget?: string;
}

const {
  title,
  description = 'Leigh Bertelsen — Build · Breathe · Be',
  theme = 'membrane',
  season,
  footerHint = 'linger here a moment',
  footerTarget = '/personal',
} = Astro.props;

// Only apply data-theme for the three public worlds (membrane stays bare).
const themeAttr = theme === 'membrane' ? undefined : theme;
---

<!doctype html>
<html lang="en" data-theme={themeAttr} data-season={season}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Google Fonts — chosen over @fontsource because Cormorant Garamond ships only the
        specific italic cuts we need (300i, 400i) and DM Sans's variable axes compress
        well when delivered via Google's CSS. See brief for exact weights. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..500;1,9..40,300..500&family=Fragment+Mono&family=Cormorant+Garamond:ital,wght@0,300;1,300;1,400&family=Lora:ital,wght@0,400;0,500;1,400&display=swap"
    />

    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only">Skip to content</a>

    <slot name="header">
      <header class="site-header">
        <a href="/" aria-label="Home" class="sigil-link">
          <Sigil size={28} />
        </a>
        <slot name="nav" />
      </header>
    </slot>

    <main id="main">
      <slot />
    </main>

    <slot name="footer">
      <footer class="site-footer">
        <button class="footer-signature" aria-label="Sigil" data-egg-sigil data-egg-target={footerTarget}>
          <Sigil size={20} />
          <span class="footer-text">{footerHint}</span>
        </button>
      </footer>
    </slot>

    <script>
      function init() {
        const btn = document.querySelector<HTMLElement>('[data-egg-sigil]');
        if (!btn) return;

        const target = btn.dataset.eggTarget || '/personal';

        function navigate() {
          window.location.assign(target);
        }

        let lastClick = 0;
        btn.addEventListener('click', () => {
          const now = Date.now();
          const gap = now - lastClick;
          lastClick = now;
          if (gap >= 100 && gap <= 600) navigate();
        });

        let pressTimer: ReturnType<typeof setTimeout> | null = null;
        btn.addEventListener('touchstart', (e) => {
          e.preventDefault();
          pressTimer = setTimeout(navigate, 600);
        }, { passive: false });
        btn.addEventListener('touchend', () => {
          if (pressTimer) { clearTimeout(pressTimer); pressTimer = null; }
        });
        btn.addEventListener('touchmove', () => {
          if (pressTimer) { clearTimeout(pressTimer); pressTimer = null; }
        });
      }

      init();
      document.addEventListener('astro:page-load', init);
    </script>

    <style>
      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1.5rem;
      }
      .sigil-link {
        display: inline-flex;
        color: var(--color-accent, var(--color-text));
      }
      .site-footer {
        padding: 3rem 1.5rem 2rem;
        display: flex;
        justify-content: center;
      }
      .footer-signature {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        opacity: 0.6;
        background: none;
        border: none;
        padding: 0.5rem;
        margin: -0.5rem;
        cursor: pointer;
        transition: opacity 200ms ease;
        transform-origin: center;
      }
      .footer-signature:hover {
        opacity: 0.85;
      }
      .footer-text {
        font-family: var(--font-sans);
        font-size: 0.875rem;
        font-weight: 300;
        font-style: italic;
        letter-spacing: 0.02em;
        color: var(--color-text-secondary, var(--color-text));
        user-select: none;
      }
      .sr-only {
        position: absolute;
        width: 1px; height: 1px;
        padding: 0; margin: -1px;
        overflow: hidden;
        clip: rect(0,0,0,0);
        white-space: nowrap;
        border: 0;
      }
      .sr-only.focus\:not-sr-only:focus {
        position: static;
        width: auto; height: auto;
        clip: auto; white-space: normal;
      }
    </style>
  </body>
</html>
