---
import BaseLayout from './BaseLayout.astro';
import { getSeason, type Season } from '@/utils/season';

interface Props {
  title: string;
  description?: string;
  season?: Season;
}

const { title, description, season: seasonOverride } = Astro.props;
// Detected at build time in static output; SSR-safe if we later flip to server output.
const season: Season = seasonOverride ?? getSeason();
---

<BaseLayout title={title} description={description} theme="breathe" season={season}>
  <slot name="nav" slot="nav" />
  <slot />
  <slot name="footer" slot="footer" />
</BaseLayout>

<style is:global>
  [data-theme="breathe"] .display {
    font-family: var(--font-serif-breathe);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(3.5rem, 6vw, 4.5rem);
    line-height: 1.1;
  }
  [data-theme="breathe"] h2 {
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-size: 2.25rem;
  }
  [data-theme="breathe"] h3 {
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-style: italic;
    font-size: 1.5rem;
  }
  [data-theme="breathe"] p {
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-size: 1.0625rem;
    line-height: 1.65;
  }
  [data-theme="breathe"] nav,
  [data-theme="breathe"] .ui {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.8125rem;
  }
  [data-theme="breathe"] .season-label {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
</style>
