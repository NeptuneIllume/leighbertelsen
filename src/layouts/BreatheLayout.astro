---
import BaseLayout from './BaseLayout.astro';
import BreatheNav from '@/components/breathe/BreatheNav.astro';
import { getSeason, type Season } from '@/utils/season';

interface Props {
  title: string;
  description?: string;
  season?: Season;
}

const { title, description, season: seasonOverride } = Astro.props;
const season: Season = seasonOverride ?? getSeason();
---

<BaseLayout title={title} description={description} theme="breathe" world="breathe" season={season}>
  <slot name="head" slot="head" />
  <BreatheNav slot="header" />
  <div transition:name="breathe-content">
    <slot />
  </div>
</BaseLayout>

<style is:global>
  /* ── Breathe dark mode token swap ───────────────────── */
  @media (prefers-color-scheme: dark) {
    [data-theme="breathe"] {
      --color-bg: var(--color-bg-dark);
      --color-surface: var(--color-surface-dark);
      --color-text-primary: var(--color-text-primary-dark);
      --color-text-secondary: var(--color-text-secondary-dark);
      --color-accent: var(--color-accent-dark);
      --color-border: var(--color-border-dark);
      --color-tab-dim: var(--color-tab-dim-dark);
    }
  }

  [data-theme="breathe"] {
    background: var(--color-bg);
    color: var(--color-text-primary);
    font-family: var(--font-sans);
  }

  /* ── Typography scale ──────────────────────────────── */
  [data-theme="breathe"] .display {
    font-family: var(--font-serif-breathe);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(56px, 7vw, 96px);
    line-height: 1.1;
  }
  [data-theme="breathe"] h2 {
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-size: 2.25rem;
  }
  [data-theme="breathe"] h3 {
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-style: italic;
    font-size: 1.5rem;
  }
  [data-theme="breathe"] p {
    font-family: var(--font-serif-breathe);
    font-weight: 400;
    font-size: 1.0625rem;
    line-height: 1.65;
  }
  [data-theme="breathe"] nav,
  [data-theme="breathe"] .ui {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.8125rem;
  }
  [data-theme="breathe"] .season-label {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
</style>
