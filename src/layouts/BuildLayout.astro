---
import BaseLayout from './BaseLayout.astro';
import BuildNav from '@/components/build/BuildNav.astro';

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description} theme="build">
  <BuildNav slot="header" />
  <div transition:name="build-content">
    <slot />
  </div>
  <slot name="footer" slot="footer" />
</BaseLayout>

<style is:global>
  /* ── Build world dark mode ─────────────────────────────
     Swap the Build tokens to their -dark counterparts when the
     user prefers dark. Scoped to [data-theme="build"] so other
     worlds remain unaffected. */
  @media (prefers-color-scheme: dark) {
    [data-theme="build"] {
      --color-bg: var(--color-bg-dark);
      --color-surface: var(--color-surface-dark);
      --color-text-primary: var(--color-text-primary-dark);
      --color-text-secondary: var(--color-text-secondary-dark);
      --color-accent: var(--color-accent-dark);
      --color-border: var(--color-border-dark);
      --color-tab-dim: var(--color-tab-dim-dark);
    }
  }

  /* ── Typography scale ──────────────────────────────── */
  [data-theme="build"] {
    background: var(--color-bg);
    color: var(--color-text-primary);
    font-family: var(--font-sans);
  }
  [data-theme="build"] .display {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(3rem, 5vw, 4rem);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  [data-theme="build"] h2 { font-family: var(--font-sans); font-weight: 500; font-size: 1.75rem; }
  [data-theme="build"] h3 { font-family: var(--font-sans); font-weight: 400; font-size: 1.25rem; }
  [data-theme="build"] p  { font-family: var(--font-sans); font-weight: 300; font-size: 1rem; line-height: 1.5; }
  [data-theme="build"] .label,
  [data-theme="build"] [data-label] {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  [data-theme="build"] .meta,
  [data-theme="build"] code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }
</style>
